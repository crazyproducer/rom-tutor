{
  "moduleId": "mod-02",
  "words": [
    { "id": "v-02-001", "ro": "Bună ziua", "en": "Good day / Hello (formal)", "uk": "Добрий день (формальне)", "pronunciation": "BOO-nuh ZEE-wah", "partOfSpeech": "phrase", "example": { "ro": "Bună ziua, mă numesc Maria.", "en": "Good day, my name is Maria.", "uk": "Добрий день, мене звати Марія." }, "notes": { "en": "Formal daytime greeting. Use this at the ceremony.", "uk": "Формальне привітання вдень. Використовуйте на церемонії." }, "tags": ["greeting", "formal", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-002", "ro": "Bună dimineața", "en": "Good morning", "uk": "Добрий ранок", "pronunciation": "BOO-nuh dee-mee-NYAH-tsah", "partOfSpeech": "phrase", "example": { "ro": "Bună dimineața! Cum vă simțiți?", "en": "Good morning! How do you feel?", "uk": "Добрий ранок! Як ви себе почуваєте?" }, "tags": ["greeting", "formal"], "difficulty": 1 },
    { "id": "v-02-003", "ro": "Bună seara", "en": "Good evening", "uk": "Добрий вечір", "pronunciation": "BOO-nuh SYAH-rah", "partOfSpeech": "phrase", "example": { "ro": "Bună seara, doamnă!", "en": "Good evening, madam!", "uk": "Добрий вечір, пані!" }, "tags": ["greeting", "formal"], "difficulty": 1 },
    { "id": "v-02-004", "ro": "Bună / Salut", "en": "Hi / Hello (informal)", "uk": "Привіт", "pronunciation": "BOO-nuh / sah-LOOT", "partOfSpeech": "phrase", "example": { "ro": "Salut! Ce faci?", "en": "Hi! How are you?", "uk": "Привіт! Як справи?" }, "notes": { "en": "Informal. Do NOT use at the ceremony.", "uk": "Неформально. НЕ використовуйте на церемонії." }, "tags": ["greeting", "informal"], "difficulty": 1 },
    { "id": "v-02-005", "ro": "La revedere", "en": "Goodbye (formal)", "uk": "До побачення", "pronunciation": "lah reh-veh-DEH-reh", "partOfSpeech": "phrase", "example": { "ro": "La revedere și mulțumesc!", "en": "Goodbye and thank you!", "uk": "До побачення і дякую!" }, "tags": ["greeting", "formal", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-006", "ro": "Pa / Pa-pa", "en": "Bye (informal)", "uk": "Бувай / Па-па", "pronunciation": "pah / pah-pah", "partOfSpeech": "phrase", "example": { "ro": "Pa! Ne vedem mâine.", "en": "Bye! See you tomorrow.", "uk": "Бувай! Побачимось завтра." }, "tags": ["greeting", "informal"], "difficulty": 1 },
    { "id": "v-02-007", "ro": "Mă numesc...", "en": "My name is...", "uk": "Мене звати...", "pronunciation": "muh noo-MESK", "partOfSpeech": "phrase", "example": { "ro": "Mă numesc Andrei Popescu.", "en": "My name is Andrei Popescu.", "uk": "Мене звати Андрій Попеску." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-008", "ro": "Cum vă numiți?", "en": "What is your name? (formal)", "uk": "Як вас звуть? (формальне)", "pronunciation": "koom vuh noo-MEETS", "partOfSpeech": "phrase", "example": { "ro": "Cum vă numiți, vă rog?", "en": "What is your name, please?", "uk": "Як вас звуть, будь ласка?" }, "tags": ["question", "formal", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-009", "ro": "Sunt din Ucraina.", "en": "I am from Ukraine.", "uk": "Я з України.", "pronunciation": "soont deen oo-krah-EE-nah", "partOfSpeech": "phrase", "example": { "ro": "Sunt din Ucraina, din orașul Kyiv.", "en": "I am from Ukraine, from the city of Kyiv.", "uk": "Я з України, з міста Київ." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-010", "ro": "Sunt din...", "en": "I am from...", "uk": "Я з...", "pronunciation": "soont deen", "partOfSpeech": "phrase", "example": { "ro": "Sunt din orașul Odesa.", "en": "I am from the city of Odessa.", "uk": "Я з міста Одеса." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-011", "ro": "Locuiesc în...", "en": "I live in...", "uk": "Я живу в...", "pronunciation": "loh-koo-YESK uhn", "partOfSpeech": "phrase", "example": { "ro": "Locuiesc în București de trei ani.", "en": "I have been living in Bucharest for three years.", "uk": "Я живу в Бухаресті три роки." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-012", "ro": "Am ... ani.", "en": "I am ... years old.", "uk": "Мені ... років.", "pronunciation": "ahm ... ahn", "partOfSpeech": "phrase", "example": { "ro": "Am treizeci și cinci de ani.", "en": "I am thirty-five years old.", "uk": "Мені тридцять п'ять років." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-013", "ro": "Sunt căsătorit / căsătorită.", "en": "I am married (m/f).", "uk": "Я одружений / одружена.", "pronunciation": "soont kuh-suh-toh-REET / kuh-suh-toh-REE-tuh", "partOfSpeech": "phrase", "example": { "ro": "Sunt căsătorit și am doi copii.", "en": "I am married and have two children.", "uk": "Я одружений і маю двох дітей." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-014", "ro": "Lucrez ca...", "en": "I work as...", "uk": "Я працюю як...", "pronunciation": "LOO-krez kah", "partOfSpeech": "phrase", "example": { "ro": "Lucrez ca inginer.", "en": "I work as an engineer.", "uk": "Я працюю інженером." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-015", "ro": "Cum sunteți?", "en": "How are you? (formal)", "uk": "Як ви? (формальне)", "pronunciation": "koom soon-TETS", "partOfSpeech": "phrase", "example": { "ro": "Bună ziua! Cum sunteți?", "en": "Good day! How are you?", "uk": "Добрий день! Як ви?" }, "tags": ["greeting", "formal"], "difficulty": 1 },
    { "id": "v-02-016", "ro": "Sunt bine, mulțumesc.", "en": "I am fine, thank you.", "uk": "Я добре, дякую.", "pronunciation": "soont BEE-neh mool-tsoo-MESK", "partOfSpeech": "phrase", "example": { "ro": "Sunt bine, mulțumesc. Dumneavoastră?", "en": "I'm fine, thank you. And you?", "uk": "Я добре, дякую. А ви?" }, "tags": ["greeting", "essential"], "difficulty": 1 },
    { "id": "v-02-017", "ro": "Îmi pare bine.", "en": "Nice to meet you. / Pleased.", "uk": "Приємно познайомитись. / Радий.", "pronunciation": "uhm PAH-reh BEE-neh", "partOfSpeech": "phrase", "example": { "ro": "Îmi pare bine de cunoștință.", "en": "Nice to meet you.", "uk": "Приємно познайомитись." }, "tags": ["greeting", "formal"], "difficulty": 1 },
    { "id": "v-02-018", "ro": "Scuzați-mă", "en": "Excuse me (formal)", "uk": "Вибачте (формальне)", "pronunciation": "skoo-ZAHTS-muh", "partOfSpeech": "phrase", "example": { "ro": "Scuzați-mă, nu am înțeles.", "en": "Excuse me, I didn't understand.", "uk": "Вибачте, я не зрозумів." }, "tags": ["politeness", "formal", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-019", "ro": "Nu am înțeles.", "en": "I didn't understand.", "uk": "Я не зрозумів/зрозуміла.", "pronunciation": "noo ahm uhn-TSEH-les", "partOfSpeech": "phrase", "example": { "ro": "Scuzați-mă, nu am înțeles. Puteți repeta?", "en": "Excuse me, I didn't understand. Can you repeat?", "uk": "Вибачте, я не зрозумів. Можете повторити?" }, "tags": ["essential", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-020", "ro": "Puteți repeta, vă rog?", "en": "Can you repeat, please? (formal)", "uk": "Можете повторити, будь ласка? (формальне)", "pronunciation": "poo-TETS reh-peh-TAH vuh rog", "partOfSpeech": "phrase", "example": { "ro": "Puteți repeta, vă rog? Mai rar.", "en": "Can you repeat, please? More slowly.", "uk": "Можете повторити, будь ласка? Повільніше." }, "tags": ["essential", "formal", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-021", "ro": "Puteți vorbi mai rar?", "en": "Can you speak more slowly? (formal)", "uk": "Можете говорити повільніше? (формальне)", "pronunciation": "poo-TETS vohr-BEE my rahr", "partOfSpeech": "phrase", "example": { "ro": "Vă rog, puteți vorbi mai rar?", "en": "Please, can you speak more slowly?", "uk": "Будь ласка, можете говорити повільніше?" }, "tags": ["essential", "formal", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-022", "ro": "domn", "en": "sir / mister", "uk": "пан", "pronunciation": "dohm-n", "partOfSpeech": "noun", "example": { "ro": "Bună ziua, domnule!", "en": "Good day, sir!", "uk": "Добрий день, пане!" }, "tags": ["formal", "title"], "difficulty": 1 },
    { "id": "v-02-023", "ro": "doamnă", "en": "madam / mrs.", "uk": "пані", "pronunciation": "DWAHM-nuh", "partOfSpeech": "noun", "example": { "ro": "Bună ziua, doamnă!", "en": "Good day, madam!", "uk": "Добрий день, пані!" }, "tags": ["formal", "title", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-024", "ro": "domnișoară", "en": "miss", "uk": "панна", "pronunciation": "dohm-nee-SHWAH-ruh", "partOfSpeech": "noun", "example": { "ro": "Bună ziua, domnișoară!", "en": "Good day, miss!", "uk": "Добрий день, панно!" }, "tags": ["formal", "title"], "difficulty": 1 },
    { "id": "v-02-025", "ro": "Cu plăcere.", "en": "You're welcome. / With pleasure.", "uk": "Будь ласка. / Із задоволенням.", "pronunciation": "koo pluh-CHEH-reh", "partOfSpeech": "phrase", "example": { "ro": "— Mulțumesc! — Cu plăcere!", "en": "— Thank you! — You're welcome!", "uk": "— Дякую! — Будь ласка!" }, "tags": ["politeness", "essential"], "difficulty": 1 },
    { "id": "v-02-026", "ro": "Vorbesc românește.", "en": "I speak Romanian.", "uk": "Я говорю румунською.", "pronunciation": "vohr-BESK roh-muh-NESHT-eh", "partOfSpeech": "phrase", "example": { "ro": "Da, vorbesc românește.", "en": "Yes, I speak Romanian.", "uk": "Так, я говорю румунською." }, "tags": ["language", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-027", "ro": "Studiez limba română de...", "en": "I have been studying Romanian for...", "uk": "Я вивчаю румунську мову...", "pronunciation": "STOO-dee-ez LEEM-bah roh-MUH-nuh deh", "partOfSpeech": "phrase", "example": { "ro": "Studiez limba română de un an.", "en": "I have been studying Romanian for one year.", "uk": "Я вивчаю румунську мову один рік." }, "tags": ["language", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-028", "ro": "Doresc cetățenia română.", "en": "I want Romanian citizenship.", "uk": "Я хочу румунське громадянство.", "pronunciation": "doh-RESK cheh-tuh-TSEH-nee-ah roh-MUH-nuh", "partOfSpeech": "phrase", "example": { "ro": "Doresc cetățenia română deoarece...", "en": "I want Romanian citizenship because...", "uk": "Я хочу румунське громадянство тому що..." }, "tags": ["ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-029", "ro": "Sunt pregătit / pregătită.", "en": "I am ready (m/f).", "uk": "Я готовий / готова.", "pronunciation": "soont preh-guh-TEET / preh-guh-TEE-tuh", "partOfSpeech": "phrase", "example": { "ro": "Da, sunt pregătit pentru depunerea jurământului.", "en": "Yes, I am ready for taking the oath.", "uk": "Так, я готовий до складання присяги." }, "tags": ["ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-030", "ro": "Respect legile României.", "en": "I respect the laws of Romania.", "uk": "Я поважаю закони Румунії.", "pronunciation": "reh-SPEKT LEH-jee-leh roh-MUH-nee-yey", "partOfSpeech": "phrase", "example": { "ro": "Respect Constituția și legile României.", "en": "I respect the Constitution and laws of Romania.", "uk": "Я поважаю Конституцію та закони Румунії." }, "tags": ["ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-031", "ro": "Noapte bună", "en": "Good night", "uk": "На добраніч", "pronunciation": "NWAHP-teh BOO-nuh", "partOfSpeech": "phrase", "example": { "ro": "Noapte bună! Ne vedem mâine.", "en": "Good night! See you tomorrow.", "uk": "На добраніч! Побачимось завтра." }, "tags": ["greeting", "informal"], "difficulty": 1 },
    { "id": "v-02-032", "ro": "Ce mai faci?", "en": "How are you? (informal)", "uk": "Як справи? (неформальне)", "pronunciation": "cheh my FAHCH", "partOfSpeech": "phrase", "example": { "ro": "Salut! Ce mai faci?", "en": "Hi! How are you?", "uk": "Привіт! Як справи?" }, "tags": ["greeting", "informal", "question"], "difficulty": 1 },
    { "id": "v-02-033", "ro": "Ce mai faceți?", "en": "How are you? (formal)", "uk": "Як ваші справи? (формальне)", "pronunciation": "cheh my fah-CHETS", "partOfSpeech": "phrase", "example": { "ro": "Bună ziua! Ce mai faceți?", "en": "Good day! How are you?", "uk": "Добрий день! Як ваші справи?" }, "tags": ["greeting", "formal", "question"], "difficulty": 1 },
    { "id": "v-02-034", "ro": "Ne vedem!", "en": "See you!", "uk": "Побачимось!", "pronunciation": "neh VEH-dem", "partOfSpeech": "phrase", "example": { "ro": "Pa! Ne vedem săptămâna viitoare.", "en": "Bye! See you next week.", "uk": "Бувай! Побачимось наступного тижня." }, "tags": ["greeting", "informal"], "difficulty": 1 },
    { "id": "v-02-035", "ro": "Pe curând!", "en": "See you soon!", "uk": "До скорого!", "pronunciation": "peh koo-RUHND", "partOfSpeech": "phrase", "example": { "ro": "La revedere! Pe curând!", "en": "Goodbye! See you soon!", "uk": "До побачення! До скорого!" }, "tags": ["greeting", "formal"], "difficulty": 1 },
    { "id": "v-02-036", "ro": "O zi bună!", "en": "Have a good day!", "uk": "Гарного дня!", "pronunciation": "oh zee BOO-nuh", "partOfSpeech": "phrase", "example": { "ro": "La revedere! O zi bună!", "en": "Goodbye! Have a good day!", "uk": "До побачення! Гарного дня!" }, "tags": ["greeting", "politeness"], "difficulty": 1 },
    { "id": "v-02-037", "ro": "Am venit din...", "en": "I came from...", "uk": "Я приїхав/приїхала з...", "pronunciation": "ahm veh-NEET deen", "partOfSpeech": "phrase", "example": { "ro": "Am venit din Ucraina acum doi ani.", "en": "I came from Ukraine two years ago.", "uk": "Я приїхав з України два роки тому." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-038", "ro": "Sunt născut în...", "en": "I was born in... (m)", "uk": "Я народився в...", "pronunciation": "soont nuh-SKOOT uhn", "partOfSpeech": "phrase", "example": { "ro": "Sunt născut în orașul Lviv.", "en": "I was born in the city of Lviv.", "uk": "Я народився в місті Львів." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-039", "ro": "Sunt născută în...", "en": "I was born in... (f)", "uk": "Я народилася в...", "pronunciation": "soont nuh-SKOO-tuh uhn", "partOfSpeech": "phrase", "example": { "ro": "Sunt născută în orașul Kyiv.", "en": "I was born in the city of Kyiv.", "uk": "Я народилася в місті Київ." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-040", "ro": "Naționalitatea mea este...", "en": "My nationality is...", "uk": "Моя національність...", "pronunciation": "nah-tsyo-nah-lee-TAH-teh myah YES-teh", "partOfSpeech": "phrase", "example": { "ro": "Naționalitatea mea este ucraineană.", "en": "My nationality is Ukrainian.", "uk": "Моя національність — українська." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-041", "ro": "profesie", "en": "profession", "uk": "професія", "pronunciation": "proh-FEH-see-eh", "partOfSpeech": "noun", "example": { "ro": "Ce profesie aveți?", "en": "What is your profession?", "uk": "Яка у вас професія?" }, "tags": ["introduction", "basic"], "difficulty": 1 },
    { "id": "v-02-042", "ro": "meserie", "en": "trade / occupation", "uk": "фах / ремесло", "pronunciation": "meh-SEH-ree-eh", "partOfSpeech": "noun", "example": { "ro": "Am o meserie bună.", "en": "I have a good trade.", "uk": "У мене гарний фах." }, "tags": ["introduction", "basic"], "difficulty": 2 },
    { "id": "v-02-043", "ro": "Sunt de profesie...", "en": "I am by profession...", "uk": "За професією я...", "pronunciation": "soont deh proh-FEH-see-eh", "partOfSpeech": "phrase", "example": { "ro": "Sunt de profesie programator.", "en": "I am a programmer by profession.", "uk": "За професією я програміст." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-044", "ro": "Am terminat universitatea.", "en": "I finished university.", "uk": "Я закінчив/закінчила університет.", "pronunciation": "ahm tehr-mee-NAHT oo-nee-vehr-see-TAH-teh", "partOfSpeech": "phrase", "example": { "ro": "Am terminat universitatea în Kyiv.", "en": "I finished university in Kyiv.", "uk": "Я закінчив університет у Києві." }, "tags": ["introduction"], "difficulty": 2 },
    { "id": "v-02-045", "ro": "Vă mulțumesc foarte mult.", "en": "Thank you very much. (formal)", "uk": "Дуже вам дякую. (формальне)", "pronunciation": "vuh mool-tsoo-MESK FWAHR-teh moolt", "partOfSpeech": "phrase", "example": { "ro": "Vă mulțumesc foarte mult pentru ajutor!", "en": "Thank you very much for the help!", "uk": "Дуже вам дякую за допомогу!" }, "tags": ["politeness", "formal", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-046", "ro": "Mă scuzați.", "en": "I'm sorry. / Excuse me. (formal)", "uk": "Вибачте. / Перепрошую. (формальне)", "pronunciation": "muh skoo-ZAHTS", "partOfSpeech": "phrase", "example": { "ro": "Mă scuzați, am întârziat.", "en": "I'm sorry, I was late.", "uk": "Вибачте, я запізнився." }, "tags": ["politeness", "formal"], "difficulty": 1 },
    { "id": "v-02-047", "ro": "Îmi pare rău.", "en": "I'm sorry. / I regret.", "uk": "Мені шкода. / Вибачте.", "pronunciation": "uhm PAH-reh RUHW", "partOfSpeech": "phrase", "example": { "ro": "Îmi pare rău, nu pot veni.", "en": "I'm sorry, I can't come.", "uk": "Мені шкода, я не можу прийти." }, "tags": ["politeness", "basic"], "difficulty": 1 },
    { "id": "v-02-048", "ro": "Nu vă supărați.", "en": "Excuse me. / Don't be upset. (formal)", "uk": "Не ображайтесь. / Вибачте. (формальне)", "pronunciation": "noo vuh soo-puh-RAHTS", "partOfSpeech": "phrase", "example": { "ro": "Nu vă supărați, unde este gara?", "en": "Excuse me, where is the train station?", "uk": "Вибачте, де знаходиться вокзал?" }, "tags": ["politeness", "formal"], "difficulty": 2 },
    { "id": "v-02-049", "ro": "Vă doresc tot binele.", "en": "I wish you all the best. (formal)", "uk": "Бажаю вам усього найкращого. (формальне)", "pronunciation": "vuh doh-RESK toht BEE-neh-leh", "partOfSpeech": "phrase", "example": { "ro": "La revedere! Vă doresc tot binele.", "en": "Goodbye! I wish you all the best.", "uk": "До побачення! Бажаю вам усього найкращого." }, "tags": ["politeness", "formal"], "difficulty": 2 },
    { "id": "v-02-050", "ro": "Cu respect", "en": "With respect / Respectfully", "uk": "З повагою", "pronunciation": "koo reh-SPEKT", "partOfSpeech": "phrase", "example": { "ro": "Cu respect, vă salut.", "en": "With respect, I greet you.", "uk": "З повагою вітаю вас." }, "tags": ["politeness", "formal"], "difficulty": 2 },
    { "id": "v-02-051", "ro": "Cu stimă", "en": "With esteem / Respectfully (in letters)", "uk": "З повагою (у листах)", "pronunciation": "koo STEE-muh", "partOfSpeech": "phrase", "example": { "ro": "Cu stimă, Andrei Popescu.", "en": "Respectfully, Andrei Popescu.", "uk": "З повагою, Андрій Попеску." }, "tags": ["politeness", "formal"], "difficulty": 2 },
    { "id": "v-02-052", "ro": "Desigur.", "en": "Of course.", "uk": "Звичайно.", "pronunciation": "deh-see-GOOR", "partOfSpeech": "adverb", "example": { "ro": "Desigur, vă pot ajuta.", "en": "Of course, I can help you.", "uk": "Звичайно, я можу вам допомогти." }, "tags": ["politeness", "basic"], "difficulty": 1 },
    { "id": "v-02-053", "ro": "Sigur.", "en": "Sure. / Certainly.", "uk": "Звісно. / Так.", "pronunciation": "see-GOOR", "partOfSpeech": "adverb", "example": { "ro": "Sigur, nicio problemă.", "en": "Sure, no problem.", "uk": "Звісно, жодних проблем." }, "tags": ["politeness", "basic"], "difficulty": 1 },
    { "id": "v-02-054", "ro": "Bineînțeles.", "en": "Of course. / Naturally.", "uk": "Безумовно. / Звичайно.", "pronunciation": "BEE-neh-uhn-tseh-LESS", "partOfSpeech": "adverb", "example": { "ro": "Bineînțeles că sunt de acord.", "en": "Of course I agree.", "uk": "Безумовно, я згоден." }, "tags": ["politeness", "basic"], "difficulty": 2 },
    { "id": "v-02-055", "ro": "Nu sunt sigur / sigură.", "en": "I'm not sure. (m/f)", "uk": "Я не впевнений / впевнена.", "pronunciation": "noo soont see-GOOR / see-GOO-ruh", "partOfSpeech": "phrase", "example": { "ro": "Nu sunt sigur dacă am înțeles corect.", "en": "I'm not sure if I understood correctly.", "uk": "Я не впевнений, чи правильно зрозумів." }, "tags": ["basic", "daily-life"], "difficulty": 1 },
    { "id": "v-02-056", "ro": "Din păcate.", "en": "Unfortunately.", "uk": "На жаль.", "pronunciation": "deen puh-KAH-teh", "partOfSpeech": "adverb", "example": { "ro": "Din păcate, nu pot veni azi.", "en": "Unfortunately, I can't come today.", "uk": "На жаль, я не можу прийти сьогодні." }, "tags": ["basic", "daily-life"], "difficulty": 2 },
    { "id": "v-02-057", "ro": "Bine ați venit!", "en": "Welcome! (formal)", "uk": "Ласкаво просимо! (формальне)", "pronunciation": "BEE-neh ahts veh-NEET", "partOfSpeech": "phrase", "example": { "ro": "Bine ați venit în România!", "en": "Welcome to Romania!", "uk": "Ласкаво просимо до Румунії!" }, "tags": ["greeting", "formal", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-058", "ro": "Felicitări!", "en": "Congratulations!", "uk": "Вітання! / Вітаю!", "pronunciation": "feh-lee-chee-TUHR", "partOfSpeech": "phrase", "example": { "ro": "Felicitări! Ați obținut cetățenia!", "en": "Congratulations! You obtained citizenship!", "uk": "Вітаю! Ви отримали громадянство!" }, "tags": ["politeness", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-059", "ro": "La mulți ani!", "en": "Happy birthday! / Many happy returns!", "uk": "З днем народження! / Многая літа!", "pronunciation": "lah MOOLT-see ahn", "partOfSpeech": "phrase", "example": { "ro": "La mulți ani! Să fii sănătos!", "en": "Happy birthday! Be healthy!", "uk": "З днем народження! Будь здоровий!" }, "tags": ["greeting", "daily-life"], "difficulty": 1 },
    { "id": "v-02-060", "ro": "Succes!", "en": "Success! / Good luck!", "uk": "Успіхів!", "pronunciation": "sook-CHES", "partOfSpeech": "phrase", "example": { "ro": "Succes la examen!", "en": "Good luck on the exam!", "uk": "Успіхів на іспиті!" }, "tags": ["politeness", "daily-life"], "difficulty": 1 },
    { "id": "v-02-061", "ro": "Noroc!", "en": "Cheers! / Good luck!", "uk": "На здоров'я! / Удачі!", "pronunciation": "noh-ROHK", "partOfSpeech": "phrase", "example": { "ro": "Noroc! Să fie bine!", "en": "Cheers! May all be well!", "uk": "На здоров'я! Хай буде добре!" }, "tags": ["greeting", "informal", "daily-life"], "difficulty": 1 },
    { "id": "v-02-062", "ro": "Sănătate!", "en": "Health! / Bless you!", "uk": "На здоров'я! / Будьте здорові!", "pronunciation": "suh-nuh-TAH-teh", "partOfSpeech": "phrase", "example": { "ro": "— Hapciu! — Sănătate!", "en": "— Achoo! — Bless you!", "uk": "— Апчхи! — Будьте здорові!" }, "tags": ["politeness", "daily-life"], "difficulty": 1 },
    { "id": "v-02-063", "ro": "Puteți să mă ajutați?", "en": "Can you help me? (formal)", "uk": "Можете мені допомогти? (формальне)", "pronunciation": "poo-TETS suh muh ah-zhoo-TAHTS", "partOfSpeech": "phrase", "example": { "ro": "Vă rog, puteți să mă ajutați cu acest formular?", "en": "Please, can you help me with this form?", "uk": "Будь ласка, можете мені допомогти з цим бланком?" }, "tags": ["question", "formal", "daily-life"], "difficulty": 2 },
    { "id": "v-02-064", "ro": "Cum se scrie...?", "en": "How do you spell...?", "uk": "Як пишеться...?", "pronunciation": "koom seh SKREE-eh", "partOfSpeech": "phrase", "example": { "ro": "Cum se scrie numele dumneavoastră?", "en": "How do you spell your name?", "uk": "Як пишеться ваше ім'я?" }, "tags": ["question", "language"], "difficulty": 2 },
    { "id": "v-02-065", "ro": "Ce înseamnă...?", "en": "What does ... mean?", "uk": "Що означає...?", "pronunciation": "cheh uhn-SYAHM-nuh", "partOfSpeech": "phrase", "example": { "ro": "Ce înseamnă acest cuvânt?", "en": "What does this word mean?", "uk": "Що означає це слово?" }, "tags": ["question", "language"], "difficulty": 1 },
    { "id": "v-02-066", "ro": "Puteți traduce?", "en": "Can you translate? (formal)", "uk": "Можете перекласти? (формальне)", "pronunciation": "poo-TETS trah-DOO-cheh", "partOfSpeech": "phrase", "example": { "ro": "Nu înțeleg. Puteți traduce în engleză?", "en": "I don't understand. Can you translate into English?", "uk": "Я не розумію. Можете перекласти англійською?" }, "tags": ["question", "formal", "language"], "difficulty": 2 },
    { "id": "v-02-067", "ro": "Vorbiți engleză?", "en": "Do you speak English? (formal)", "uk": "Ви розмовляєте англійською? (формальне)", "pronunciation": "vohr-BEETS en-GLEH-zuh", "partOfSpeech": "phrase", "example": { "ro": "Scuzați-mă, vorbiți engleză?", "en": "Excuse me, do you speak English?", "uk": "Вибачте, ви розмовляєте англійською?" }, "tags": ["question", "formal", "language"], "difficulty": 1 },
    { "id": "v-02-068", "ro": "Sunt cetățean român.", "en": "I am a Romanian citizen. (m)", "uk": "Я громадянин Румунії.", "pronunciation": "soont cheh-tuh-TSYAHN roh-MUHN", "partOfSpeech": "phrase", "example": { "ro": "De astăzi, sunt cetățean român.", "en": "As of today, I am a Romanian citizen.", "uk": "Від сьогодні я громадянин Румунії." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-069", "ro": "Sunt cetățeană română.", "en": "I am a Romanian citizen. (f)", "uk": "Я громадянка Румунії.", "pronunciation": "soont cheh-tuh-TSYAH-nuh roh-MUH-nuh", "partOfSpeech": "phrase", "example": { "ro": "De astăzi, sunt cetățeană română.", "en": "As of today, I am a Romanian citizen.", "uk": "Від сьогодні я громадянка Румунії." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-070", "ro": "Am depus dosarul.", "en": "I submitted the file/application.", "uk": "Я подав/подала досьє.", "pronunciation": "ahm deh-POOS doh-SAH-rool", "partOfSpeech": "phrase", "example": { "ro": "Am depus dosarul pentru cetățenie anul trecut.", "en": "I submitted the citizenship application last year.", "uk": "Я подав досьє на громадянство минулого року." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-071", "ro": "Locuiesc în România de ... ani.", "en": "I have lived in Romania for ... years.", "uk": "Я живу в Румунії ... років.", "pronunciation": "loh-koo-YESK uhn roh-MUH-nee-ah deh ... ahn", "partOfSpeech": "phrase", "example": { "ro": "Locuiesc în România de cinci ani.", "en": "I have lived in Romania for five years.", "uk": "Я живу в Румунії п'ять років." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-072", "ro": "Sunt angajat la...", "en": "I am employed at... (m)", "uk": "Я працевлаштований в...", "pronunciation": "soont ahn-gah-ZHAHT lah", "partOfSpeech": "phrase", "example": { "ro": "Sunt angajat la o companie IT din Cluj.", "en": "I am employed at an IT company in Cluj.", "uk": "Я працевлаштований в ІТ-компанії у Клужі." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-073", "ro": "Sunt angajată la...", "en": "I am employed at... (f)", "uk": "Я працевлаштована в...", "pronunciation": "soont ahn-gah-ZHAH-tuh lah", "partOfSpeech": "phrase", "example": { "ro": "Sunt angajată la un spital din București.", "en": "I am employed at a hospital in Bucharest.", "uk": "Я працевлаштована в лікарні у Бухаресті." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-074", "ro": "Am familie în România.", "en": "I have family in Romania.", "uk": "У мене є родина в Румунії.", "pronunciation": "ahm fah-MEE-lee-eh uhn roh-MUH-nee-ah", "partOfSpeech": "phrase", "example": { "ro": "Am familie în România, soția mea este româncă.", "en": "I have family in Romania, my wife is Romanian.", "uk": "У мене є родина в Румунії, моя дружина — румунка." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-075", "ro": "Soțul meu este...", "en": "My husband is...", "uk": "Мій чоловік...", "pronunciation": "SOH-tsool myoo YES-teh", "partOfSpeech": "phrase", "example": { "ro": "Soțul meu este român.", "en": "My husband is Romanian.", "uk": "Мій чоловік — румун." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-076", "ro": "Soția mea este...", "en": "My wife is...", "uk": "Моя дружина...", "pronunciation": "SOH-tsee-ah myah YES-teh", "partOfSpeech": "phrase", "example": { "ro": "Soția mea este româncă.", "en": "My wife is Romanian.", "uk": "Моя дружина — румунка." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-077", "ro": "Copiii mei se numesc...", "en": "My children are named...", "uk": "Моїх дітей звати...", "pronunciation": "koh-PEE-ee myay seh noo-MESK", "partOfSpeech": "phrase", "example": { "ro": "Copiii mei se numesc Maria și Ion.", "en": "My children are named Maria and Ion.", "uk": "Моїх дітей звати Марія та Іон." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-078", "ro": "Am un copil. / Am doi copii.", "en": "I have one child. / I have two children.", "uk": "У мене одна дитина. / У мене двоє дітей.", "pronunciation": "ahm oon koh-PEEL / ahm doy koh-PEE", "partOfSpeech": "phrase", "example": { "ro": "Am doi copii, o fată și un băiat.", "en": "I have two children, a girl and a boy.", "uk": "У мене двоє дітей, дівчинка і хлопчик." }, "tags": ["introduction", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-02-079", "ro": "Înțeleg.", "en": "I understand.", "uk": "Я розумію.", "pronunciation": "uhn-TSEH-leg", "partOfSpeech": "verb", "example": { "ro": "Da, înțeleg ce spuneți.", "en": "Yes, I understand what you are saying.", "uk": "Так, я розумію, що ви кажете." }, "tags": ["basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-080", "ro": "Nu înțeleg.", "en": "I don't understand.", "uk": "Я не розумію.", "pronunciation": "noo uhn-TSEH-leg", "partOfSpeech": "phrase", "example": { "ro": "Îmi pare rău, nu înțeleg.", "en": "I'm sorry, I don't understand.", "uk": "Вибачте, я не розумію." }, "tags": ["basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-081", "ro": "Vă rog.", "en": "Please. (formal)", "uk": "Будь ласка. (формальне)", "pronunciation": "vuh ROHG", "partOfSpeech": "phrase", "example": { "ro": "Vă rog, spuneți-mi unde este sala.", "en": "Please, tell me where the hall is.", "uk": "Будь ласка, скажіть мені, де зала." }, "tags": ["politeness", "formal", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-082", "ro": "Mulțumesc.", "en": "Thank you.", "uk": "Дякую.", "pronunciation": "mool-tsoo-MESK", "partOfSpeech": "phrase", "example": { "ro": "Mulțumesc pentru informație.", "en": "Thank you for the information.", "uk": "Дякую за інформацію." }, "tags": ["politeness", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-02-083", "ro": "Da.", "en": "Yes.", "uk": "Так.", "pronunciation": "dah", "partOfSpeech": "adverb", "example": { "ro": "Da, sunt de acord.", "en": "Yes, I agree.", "uk": "Так, я згоден." }, "tags": ["basic"], "difficulty": 1 },
    { "id": "v-02-084", "ro": "Nu.", "en": "No.", "uk": "Ні.", "pronunciation": "noo", "partOfSpeech": "adverb", "example": { "ro": "Nu, mulțumesc.", "en": "No, thank you.", "uk": "Ні, дякую." }, "tags": ["basic"], "difficulty": 1 },
