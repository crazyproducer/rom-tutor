{
  "moduleId": "mod-01",
  "words": [
    { "id": "v-01-001", "ro": "a", "en": "a (letter)", "uk": "а (літера)", "pronunciation": "ah", "partOfSpeech": "letter", "example": { "ro": "Ana are o carte.", "en": "Ana has a book.", "uk": "Ана має книгу." }, "tags": ["alphabet"], "difficulty": 1 },
    { "id": "v-01-002", "ro": "ă", "en": "ă (special letter)", "uk": "ă (спеціальна літера)", "pronunciation": "uh (like 'a' in 'about')", "partOfSpeech": "letter", "example": { "ro": "băiat", "en": "boy", "uk": "хлопець" }, "notes": { "en": "Similar to the unstressed 'a' in English 'about'. Very common in Romanian.", "uk": "Схожа на ненаголошену 'а' в англ. 'about'. Дуже поширена в румунській." }, "tags": ["alphabet", "special"], "difficulty": 1 },
    { "id": "v-01-003", "ro": "â / î", "en": "â/î (deep vowel)", "uk": "â/î (глибокий голосний)", "pronunciation": "uhn (no English equivalent)", "partOfSpeech": "letter", "example": { "ro": "România, în", "en": "Romania, in", "uk": "Румунія, в" }, "notes": { "en": "â is used in the middle of words, î at the beginning/end. Same sound. Similar to Russian 'ы'.", "uk": "â вживається в середині слів, î — на початку/кінці. Однаковий звук. Схожий на російське 'ы'." }, "tags": ["alphabet", "special"], "difficulty": 2 },
    { "id": "v-01-004", "ro": "ș", "en": "ș (sh sound)", "uk": "ș (звук ш)", "pronunciation": "sh", "partOfSpeech": "letter", "example": { "ro": "și, școală", "en": "and, school", "uk": "і, школа" }, "notes": { "en": "Pronounced like English 'sh' in 'she'. Always 'sh' sound.", "uk": "Вимовляється як 'ш' в українській. Завжди звук 'ш'." }, "tags": ["alphabet", "special"], "difficulty": 1 },
    { "id": "v-01-005", "ro": "ț", "en": "ț (ts sound)", "uk": "ț (звук ц)", "pronunciation": "ts", "partOfSpeech": "letter", "example": { "ro": "țară, Constituție", "en": "country, Constitution", "uk": "країна, Конституція" }, "notes": { "en": "Pronounced like 'ts' in 'cats'. Same as Ukrainian 'ц'.", "uk": "Вимовляється як українське 'ц'. Однаковий звук." }, "tags": ["alphabet", "special"], "difficulty": 1 },
    { "id": "v-01-006", "ro": "da", "en": "yes", "uk": "так", "pronunciation": "dah", "partOfSpeech": "adverb", "example": { "ro": "Da, sunt din Ucraina.", "en": "Yes, I am from Ukraine.", "uk": "Так, я з України." }, "tags": ["basic", "essential"], "difficulty": 1 },
    { "id": "v-01-007", "ro": "nu", "en": "no / not", "uk": "ні / не", "pronunciation": "noo", "partOfSpeech": "adverb", "example": { "ro": "Nu, mulțumesc.", "en": "No, thank you.", "uk": "Ні, дякую." }, "tags": ["basic", "essential"], "difficulty": 1 },
    { "id": "v-01-008", "ro": "și", "en": "and", "uk": "і / та", "pronunciation": "shee", "partOfSpeech": "conjunction", "example": { "ro": "eu și tu", "en": "me and you", "uk": "я і ти" }, "tags": ["basic", "essential"], "difficulty": 1 },
    { "id": "v-01-009", "ro": "eu", "en": "I", "uk": "я", "pronunciation": "yeh-oo", "partOfSpeech": "pronoun", "example": { "ro": "Eu sunt student.", "en": "I am a student.", "uk": "Я студент." }, "tags": ["pronoun", "essential"], "difficulty": 1 },
    { "id": "v-01-010", "ro": "tu", "en": "you (informal)", "uk": "ти", "pronunciation": "too", "partOfSpeech": "pronoun", "example": { "ro": "Tu ești aici.", "en": "You are here.", "uk": "Ти тут." }, "tags": ["pronoun", "essential"], "difficulty": 1 },
    { "id": "v-01-011", "ro": "el / ea", "en": "he / she", "uk": "він / вона", "pronunciation": "yel / yah", "partOfSpeech": "pronoun", "example": { "ro": "El este profesor. Ea este doctoriță.", "en": "He is a teacher. She is a doctor.", "uk": "Він учитель. Вона лікарка." }, "tags": ["pronoun", "essential"], "difficulty": 1 },
    { "id": "v-01-012", "ro": "noi", "en": "we", "uk": "ми", "pronunciation": "noy", "partOfSpeech": "pronoun", "example": { "ro": "Noi suntem prieteni.", "en": "We are friends.", "uk": "Ми друзі." }, "tags": ["pronoun", "essential"], "difficulty": 1 },
    { "id": "v-01-013", "ro": "voi", "en": "you (plural)", "uk": "ви", "pronunciation": "voy", "partOfSpeech": "pronoun", "example": { "ro": "Voi sunteți din Ucraina.", "en": "You are from Ukraine.", "uk": "Ви з України." }, "tags": ["pronoun", "essential"], "difficulty": 1 },
    { "id": "v-01-014", "ro": "ei / ele", "en": "they (m/f)", "uk": "вони (чол./жін.)", "pronunciation": "yey / yeh-leh", "partOfSpeech": "pronoun", "example": { "ro": "Ei sunt aici. Ele sunt acolo.", "en": "They (m) are here. They (f) are there.", "uk": "Вони (чол.) тут. Вони (жін.) там." }, "tags": ["pronoun"], "difficulty": 2 },
    { "id": "v-01-015", "ro": "dumneavoastră", "en": "you (formal)", "uk": "Ви (формальне)", "pronunciation": "doom-neh-ah-VOAHS-truh", "partOfSpeech": "pronoun", "example": { "ro": "Dumneavoastră sunteți bine venit.", "en": "You are welcome. (formal)", "uk": "Ви ласкаво просимо. (формальне)" }, "notes": { "en": "Used in formal situations. ESSENTIAL for the ceremony - always use this with officials.", "uk": "Вживається у формальних ситуаціях. ОБОВ'ЯЗКОВО на церемонії — завжди використовуйте з офіціалами." }, "tags": ["pronoun", "formal", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-01-016", "ro": "sunt", "en": "I am / they are", "uk": "я є / вони є", "pronunciation": "soont", "partOfSpeech": "verb", "example": { "ro": "Eu sunt din Ucraina.", "en": "I am from Ukraine.", "uk": "Я з України." }, "tags": ["verb", "essential"], "difficulty": 1 },
    { "id": "v-01-017", "ro": "ești", "en": "you are (informal)", "uk": "ти є", "pronunciation": "yesht", "partOfSpeech": "verb", "example": { "ro": "Tu ești frumoasă.", "en": "You are beautiful.", "uk": "Ти красива." }, "tags": ["verb", "essential"], "difficulty": 1 },
    { "id": "v-01-018", "ro": "este", "en": "he/she/it is", "uk": "він/вона/воно є", "pronunciation": "YES-teh", "partOfSpeech": "verb", "example": { "ro": "El este român.", "en": "He is Romanian.", "uk": "Він румун." }, "tags": ["verb", "essential"], "difficulty": 1 },
    { "id": "v-01-019", "ro": "suntem", "en": "we are", "uk": "ми є", "pronunciation": "SOON-tem", "partOfSpeech": "verb", "example": { "ro": "Noi suntem aici.", "en": "We are here.", "uk": "Ми тут." }, "tags": ["verb", "essential"], "difficulty": 1 },
    { "id": "v-01-020", "ro": "sunteți", "en": "you are (formal/plural)", "uk": "ви є", "pronunciation": "soon-TETS", "partOfSpeech": "verb", "example": { "ro": "Dumneavoastră sunteți pregătit?", "en": "Are you ready? (formal)", "uk": "Ви готові? (формальне)" }, "tags": ["verb", "essential", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-021", "ro": "am", "en": "I have", "uk": "я маю", "pronunciation": "ahm", "partOfSpeech": "verb", "example": { "ro": "Eu am o familie.", "en": "I have a family.", "uk": "Я маю родину." }, "tags": ["verb", "essential"], "difficulty": 1 },
    { "id": "v-01-022", "ro": "avem", "en": "we have", "uk": "ми маємо", "pronunciation": "ah-VEM", "partOfSpeech": "verb", "example": { "ro": "Avem documente pregătite.", "en": "We have the documents ready.", "uk": "Ми маємо документи готові." }, "tags": ["verb"], "difficulty": 1 },
    { "id": "v-01-023", "ro": "aveți", "en": "you have (formal/plural)", "uk": "ви маєте", "pronunciation": "ah-VETS", "partOfSpeech": "verb", "example": { "ro": "Aveți actele de identitate?", "en": "Do you have the identity documents?", "uk": "Ви маєте документи?" }, "tags": ["verb", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-024", "ro": "bine", "en": "well / good / fine", "uk": "добре / гарно", "pronunciation": "BEE-neh", "partOfSpeech": "adverb", "example": { "ro": "Sunt bine, mulțumesc.", "en": "I am fine, thank you.", "uk": "Я добре, дякую." }, "tags": ["basic", "essential"], "difficulty": 1 },
    { "id": "v-01-025", "ro": "mulțumesc", "en": "thank you", "uk": "дякую", "pronunciation": "mool-tsoo-MESK", "partOfSpeech": "verb", "example": { "ro": "Mulțumesc foarte mult!", "en": "Thank you very much!", "uk": "Дуже дякую!" }, "tags": ["basic", "essential", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-026", "ro": "vă rog", "en": "please (formal)", "uk": "будь ласка (формальне)", "pronunciation": "vuh ROG", "partOfSpeech": "phrase", "example": { "ro": "Vă rog să repetați.", "en": "Please repeat.", "uk": "Будь ласка, повторіть." }, "tags": ["basic", "formal", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-027", "ro": "România", "en": "Romania", "uk": "Румунія", "pronunciation": "roh-MUH-nee-ah", "partOfSpeech": "noun", "example": { "ro": "România este în Europa.", "en": "Romania is in Europe.", "uk": "Румунія в Європі." }, "tags": ["geography", "essential"], "difficulty": 1 },
    { "id": "v-01-028", "ro": "român / româncă", "en": "Romanian (m/f)", "uk": "румун / румунка", "pronunciation": "roh-MUHN / roh-MUHN-kuh", "partOfSpeech": "noun", "example": { "ro": "Sunt cetățean român.", "en": "I am a Romanian citizen.", "uk": "Я громадянин Румунії." }, "tags": ["nationality", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-029", "ro": "limba română", "en": "Romanian language", "uk": "румунська мова", "pronunciation": "LEEM-bah roh-MUH-nuh", "partOfSpeech": "phrase", "example": { "ro": "Studiez limba română.", "en": "I study the Romanian language.", "uk": "Я вивчаю румунську мову." }, "tags": ["language", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-030", "ro": "ce", "en": "what", "uk": "що", "pronunciation": "cheh", "partOfSpeech": "pronoun", "example": { "ro": "Ce faceți?", "en": "How are you? (formal)", "uk": "Як справи? (формальне)" }, "tags": ["question", "essential"], "difficulty": 1 },
    { "id": "v-01-031", "ro": "cine", "en": "who", "uk": "хто", "pronunciation": "CHEE-neh", "partOfSpeech": "pronoun", "example": { "ro": "Cine sunteți?", "en": "Who are you?", "uk": "Хто ви?" }, "tags": ["question", "essential"], "difficulty": 1 },
    { "id": "v-01-032", "ro": "unde", "en": "where", "uk": "де", "pronunciation": "OON-deh", "partOfSpeech": "adverb", "example": { "ro": "Unde locuiți?", "en": "Where do you live?", "uk": "Де ви живете?" }, "tags": ["question", "essential", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-033", "ro": "când", "en": "when", "uk": "коли", "pronunciation": "kuhnd", "partOfSpeech": "adverb", "example": { "ro": "Când v-ați născut?", "en": "When were you born?", "uk": "Коли ви народились?" }, "tags": ["question", "essential", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-034", "ro": "de ce", "en": "why", "uk": "чому", "pronunciation": "deh cheh", "partOfSpeech": "phrase", "example": { "ro": "De ce doriți cetățenia?", "en": "Why do you want citizenship?", "uk": "Чому ви хочете громадянство?" }, "tags": ["question", "essential", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-035", "ro": "cum", "en": "how", "uk": "як", "pronunciation": "koom", "partOfSpeech": "adverb", "example": { "ro": "Cum vă numiți?", "en": "What is your name? (formal)", "uk": "Як вас звуть? (формальне)" }, "tags": ["question", "essential", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-036", "ro": "aici", "en": "here", "uk": "тут", "pronunciation": "ah-EECH", "partOfSpeech": "adverb", "example": { "ro": "Locuiesc aici de doi ani.", "en": "I have lived here for two years.", "uk": "Я живу тут два роки." }, "tags": ["basic"], "difficulty": 1 },
    { "id": "v-01-037", "ro": "acolo", "en": "there", "uk": "там", "pronunciation": "ah-KOH-loh", "partOfSpeech": "adverb", "example": { "ro": "Acolo este biroul.", "en": "The office is there.", "uk": "Там офіс." }, "tags": ["basic"], "difficulty": 1 },
    { "id": "v-01-038", "ro": "foarte", "en": "very", "uk": "дуже", "pronunciation": "FOAHR-teh", "partOfSpeech": "adverb", "example": { "ro": "Foarte bine, mulțumesc.", "en": "Very well, thank you.", "uk": "Дуже добре, дякую." }, "tags": ["basic", "essential"], "difficulty": 1 },
    { "id": "v-01-039", "ro": "mare", "en": "big / large", "uk": "великий", "pronunciation": "MAH-reh", "partOfSpeech": "adjective", "example": { "ro": "România este o țară mare.", "en": "Romania is a big country.", "uk": "Румунія — велика країна." }, "tags": ["adjective", "basic"], "difficulty": 1 },
    { "id": "v-01-040", "ro": "mic", "en": "small / little", "uk": "маленький", "pronunciation": "meek", "partOfSpeech": "adjective", "example": { "ro": "Am un copil mic.", "en": "I have a small child.", "uk": "У мене маленька дитина." }, "tags": ["adjective", "basic"], "difficulty": 1 },
    { "id": "v-01-041", "ro": "bun / bună", "en": "good (m/f)", "uk": "добрий / добра", "pronunciation": "boon / BOO-nuh", "partOfSpeech": "adjective", "example": { "ro": "O zi bună!", "en": "A good day!", "uk": "Гарного дня!" }, "tags": ["adjective", "essential"], "difficulty": 1 },
    { "id": "v-01-042", "ro": "om", "en": "person / human", "uk": "людина", "pronunciation": "ohm", "partOfSpeech": "noun", "example": { "ro": "Este un om bun.", "en": "He is a good person.", "uk": "Він добра людина." }, "tags": ["noun", "basic"], "difficulty": 1 },
    { "id": "v-01-043", "ro": "țară", "en": "country", "uk": "країна", "pronunciation": "TSAH-ruh", "partOfSpeech": "noun", "example": { "ro": "România este țara mea.", "en": "Romania is my country.", "uk": "Румунія — моя країна." }, "tags": ["noun", "essential", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-044", "ro": "cetățean", "en": "citizen", "uk": "громадянин", "pronunciation": "cheh-tuh-TSEHN", "partOfSpeech": "noun", "example": { "ro": "Vreau să devin cetățean român.", "en": "I want to become a Romanian citizen.", "uk": "Я хочу стати громадянином Румунії." }, "tags": ["noun", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-01-045", "ro": "cetățenie", "en": "citizenship", "uk": "громадянство", "pronunciation": "cheh-tuh-TSEH-nee-eh", "partOfSpeech": "noun", "example": { "ro": "Am depus cererea pentru cetățenie.", "en": "I submitted the application for citizenship.", "uk": "Я подав заяву на громадянство." }, "tags": ["noun", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-01-046", "ro": "jurământ", "en": "oath", "uk": "присяга", "pronunciation": "zhoo-ruh-MUHNT", "partOfSpeech": "noun", "example": { "ro": "Depun jurământul de credință.", "en": "I take the oath of allegiance.", "uk": "Я складаю присягу на вірність." }, "tags": ["noun", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-01-047", "ro": "document", "en": "document", "uk": "документ", "pronunciation": "doh-koo-MENT", "partOfSpeech": "noun", "example": { "ro": "Aveți toate documentele?", "en": "Do you have all the documents?", "uk": "У вас є всі документи?" }, "tags": ["noun", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-048", "ro": "înțeleg", "en": "I understand", "uk": "я розумію", "pronunciation": "uhn-TSEH-leg", "partOfSpeech": "verb", "example": { "ro": "Înțeleg limba română.", "en": "I understand the Romanian language.", "uk": "Я розумію румунську мову." }, "tags": ["verb", "essential"], "difficulty": 2 },
    { "id": "v-01-049", "ro": "vorbesc", "en": "I speak", "uk": "я говорю", "pronunciation": "vohr-BESK", "partOfSpeech": "verb", "example": { "ro": "Vorbesc puțin românește.", "en": "I speak a little Romanian.", "uk": "Я говорю трохи румунською." }, "tags": ["verb", "essential", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-01-050", "ro": "locuiesc", "en": "I live (reside)", "uk": "я живу (мешкаю)", "pronunciation": "loh-koo-YESK", "partOfSpeech": "verb", "example": { "ro": "Locuiesc în București.", "en": "I live in Bucharest.", "uk": "Я живу в Бухаресті." }, "tags": ["verb", "essential", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-01-051", "ro": "a face", "en": "to do / to make", "uk": "робити", "pronunciation": "ah FAH-cheh", "partOfSpeech": "verb", "example": { "ro": "Ce faceți?", "en": "How are you? (formal) / What are you doing?", "uk": "Як справи? (формальне) / Що ви робите?" }, "tags": ["verb", "essential", "daily-life"], "difficulty": 1 },
    { "id": "v-01-052", "ro": "a merge", "en": "to go / to walk", "uk": "йти / ходити", "pronunciation": "ah MEHR-djeh", "partOfSpeech": "verb", "example": { "ro": "Merg la lucru în fiecare zi.", "en": "I go to work every day.", "uk": "Я ходжу на роботу кожного дня." }, "tags": ["verb", "essential", "daily-life"], "difficulty": 1 },
    { "id": "v-01-053", "ro": "a veni", "en": "to come", "uk": "приходити", "pronunciation": "ah veh-NEE", "partOfSpeech": "verb", "example": { "ro": "Veniți mâine la birou.", "en": "Come to the office tomorrow.", "uk": "Приходьте завтра до офісу." }, "tags": ["verb", "essential", "daily-life"], "difficulty": 1 },
    { "id": "v-01-054", "ro": "a ști", "en": "to know", "uk": "знати", "pronunciation": "ah shtee", "partOfSpeech": "verb", "example": { "ro": "Știu limba română.", "en": "I know the Romanian language.", "uk": "Я знаю румунську мову." }, "tags": ["verb", "essential", "daily-life"], "difficulty": 1 },
    { "id": "v-01-055", "ro": "a vrea", "en": "to want", "uk": "хотіти", "pronunciation": "ah vreh-AH", "partOfSpeech": "verb", "example": { "ro": "Vreau să devin cetățean.", "en": "I want to become a citizen.", "uk": "Я хочу стати громадянином." }, "tags": ["verb", "essential", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-01-056", "ro": "a putea", "en": "to be able to / can", "uk": "могти", "pronunciation": "ah poo-TEH-ah", "partOfSpeech": "verb", "example": { "ro": "Puteți repeta, vă rog?", "en": "Can you repeat, please?", "uk": "Чи можете повторити, будь ласка?" }, "tags": ["verb", "essential", "daily-life"], "difficulty": 1 },
    { "id": "v-01-057", "ro": "a vedea", "en": "to see", "uk": "бачити", "pronunciation": "ah veh-DEH-ah", "partOfSpeech": "verb", "example": { "ro": "Văd documentele pe masă.", "en": "I see the documents on the table.", "uk": "Я бачу документи на столі." }, "tags": ["verb", "basic", "daily-life"], "difficulty": 1 },
    { "id": "v-01-058", "ro": "a da", "en": "to give", "uk": "давати", "pronunciation": "ah dah", "partOfSpeech": "verb", "example": { "ro": "Vă dau pașaportul.", "en": "I give you the passport.", "uk": "Я даю вам паспорт." }, "tags": ["verb", "basic", "daily-life"], "difficulty": 1 },
    { "id": "v-01-059", "ro": "a lua", "en": "to take", "uk": "брати", "pronunciation": "ah loo-AH", "partOfSpeech": "verb", "example": { "ro": "Luați loc, vă rog.", "en": "Please take a seat.", "uk": "Сідайте, будь ласка." }, "tags": ["verb", "basic", "formal"], "difficulty": 1 },
    { "id": "v-01-060", "ro": "a citi", "en": "to read", "uk": "читати", "pronunciation": "ah chee-TEE", "partOfSpeech": "verb", "example": { "ro": "Citiți textul jurământului.", "en": "Read the text of the oath.", "uk": "Прочитайте текст присяги." }, "tags": ["verb", "basic", "ceremony-essential"], "difficulty": 1 },
