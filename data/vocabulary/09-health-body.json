    { "id": "v-09-016", "ro": "durere de cap", "en": "headache", "uk": "головний біль", "pronunciation": "doo-REH-reh deh kahp", "partOfSpeech": "phrase", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Am o durere de cap groaznică.", "en": "I have a terrible headache.", "uk": "У мене жахливий головний біль." } },
    { "id": "v-09-017", "ro": "febră", "en": "fever", "uk": "гарячка", "pronunciation": "FEH-bruh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life", "basic"], "example": { "ro": "Copilul are febră mare.", "en": "The child has a high fever.", "uk": "У дитини висока температура." } },
    { "id": "v-09-018", "ro": "răceală", "en": "cold (illness)", "uk": "застуда", "pronunciation": "ruh-CHAH-luh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Am răcit și am răceală.", "en": "I caught a cold.", "uk": "Я застудився і маю застуду." } },
    { "id": "v-09-019", "ro": "tuse", "en": "cough", "uk": "кашель", "pronunciation": "TOO-seh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Am o tuse puternică.", "en": "I have a strong cough.", "uk": "У мене сильний кашель." } },
    { "id": "v-09-020", "ro": "durere", "en": "pain", "uk": "біль", "pronunciation": "doo-REH-reh", "partOfSpeech": "noun", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Simt o durere puternică.", "en": "I feel a strong pain.", "uk": "Я відчуваю сильний біль." } },
    { "id": "v-09-021", "ro": "alergie", "en": "allergy", "uk": "алергія", "pronunciation": "ah-lehr-ZHEE-eh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Am alergie la polen.", "en": "I am allergic to pollen.", "uk": "У мене алергія на пилок." } },
    { "id": "v-09-022", "ro": "gripă", "en": "flu / influenza", "uk": "грип", "pronunciation": "GREE-puh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Iarna mulți oameni fac gripă.", "en": "In winter many people get the flu.", "uk": "Взимку багато людей хворіють на грип." } },
    { "id": "v-09-023", "ro": "infecție", "en": "infection", "uk": "інфекція", "pronunciation": "een-FEHK-tsee-eh", "partOfSpeech": "noun", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "Rana are o infecție.", "en": "The wound has an infection.", "uk": "Рана має інфекцію." } },
    { "id": "v-09-024", "ro": "amețeală", "en": "dizziness", "uk": "запаморочення", "pronunciation": "ah-meh-TSAH-luh", "partOfSpeech": "noun", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "Am amețeli de câteva zile.", "en": "I've been having dizziness for several days.", "uk": "У мене запаморочення кілька днів." } },
    { "id": "v-09-025", "ro": "greață", "en": "nausea", "uk": "нудота", "pronunciation": "GREH-ah-tsuh", "partOfSpeech": "noun", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "Am greață de ieri.", "en": "I've had nausea since yesterday.", "uk": "Мене нудить від учора." } },
    { "id": "v-09-026", "ro": "rană", "en": "wound", "uk": "рана", "pronunciation": "RAH-nuh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Rana trebuie curățată.", "en": "The wound needs to be cleaned.", "uk": "Рану потрібно очистити." } },
    { "id": "v-09-027", "ro": "tensiune", "en": "blood pressure", "uk": "тиск", "pronunciation": "tehn-see-OO-neh", "partOfSpeech": "noun", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "Am tensiunea ridicată.", "en": "I have high blood pressure.", "uk": "У мене підвищений тиск." } },
    { "id": "v-09-028", "ro": "spital", "en": "hospital", "uk": "лікарня", "pronunciation": "spee-TAHL", "partOfSpeech": "noun", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Trebuie să merg la spital.", "en": "I need to go to the hospital.", "uk": "Мені потрібно поїхати до лікарні." } },
    { "id": "v-09-029", "ro": "clinică", "en": "clinic", "uk": "клініка", "pronunciation": "KLEE-nee-kuh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Clinica este deschisă de la opt.", "en": "The clinic is open from eight.", "uk": "Клініка працює з восьмої." } },
    { "id": "v-09-030", "ro": "farmacie", "en": "pharmacy", "uk": "аптека", "pronunciation": "fahr-mah-CHEE-eh", "partOfSpeech": "noun", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Unde este cea mai apropiată farmacie?", "en": "Where is the nearest pharmacy?", "uk": "Де найближча аптека?" } },
    { "id": "v-09-031", "ro": "doctor", "en": "doctor", "uk": "лікар", "pronunciation": "DOHK-tohr", "partOfSpeech": "noun", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Trebuie să merg la doctor.", "en": "I need to go to the doctor.", "uk": "Мені потрібно піти до лікаря." }, "notes": { "en": "'Medic' is also commonly used for doctor in Romanian.", "uk": "'Medic' також часто використовується для лікаря в румунській мові." } },
    { "id": "v-09-032", "ro": "medic", "en": "physician / doctor", "uk": "лікар / медик", "pronunciation": "MEH-deek", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Medicul de familie m-a consultat.", "en": "The family doctor examined me.", "uk": "Сімейний лікар мене оглянув." } },
