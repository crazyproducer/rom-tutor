    { "id": "v-09-040", "ro": "a examina", "en": "to examine", "uk": "оглядати", "pronunciation": "ah ehg-zah-mee-NAH", "partOfSpeech": "verb", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Doctorul m-a examinat cu atenție.", "en": "The doctor examined me carefully.", "uk": "Лікар уважно мене оглянув." } },
    { "id": "v-09-041", "ro": "a prescrie", "en": "to prescribe", "uk": "призначати / виписувати", "pronunciation": "ah prehs-KREE-eh", "partOfSpeech": "verb", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "Doctorul mi-a prescris antibiotice.", "en": "The doctor prescribed me antibiotics.", "uk": "Лікар призначив мені антибіотики." } },
