  "words": [
    { "id": "v-09-001", "ro": "cap", "en": "head", "uk": "голова", "pronunciation": "kahp", "partOfSpeech": "noun", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Mă doare capul.", "en": "My head hurts.", "uk": "У мене болить голова." } },
