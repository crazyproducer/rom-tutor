    { "id": "v-09-008", "ro": "mână", "en": "hand / arm", "uk": "рука", "pronunciation": "MUH-nuh", "partOfSpeech": "noun", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "M-am rănit la mână.", "en": "I hurt my hand.", "uk": "Я поранив руку." }, "notes": { "en": "'Mână' can refer to both hand and arm, similar to Ukrainian 'рука'.", "uk": "'Mână' означає і руку, і кисть, як в українській 'рука'." } },
