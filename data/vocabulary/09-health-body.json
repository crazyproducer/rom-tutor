    { "id": "v-09-046", "ro": "a opera", "en": "to operate (surgery)", "uk": "оперувати", "pronunciation": "ah oh-peh-RAH", "partOfSpeech": "verb", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "Doctorul a operat pacientul.", "en": "The doctor operated on the patient.", "uk": "Лікар прооперував пацієнта." } },
    { "id": "v-09-047", "ro": "a consulta", "en": "to consult / to see a doctor", "uk": "консультуватися", "pronunciation": "ah kohn-sool-TAH", "partOfSpeech": "verb", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "Trebuie să consult un specialist.", "en": "I need to consult a specialist.", "uk": "Мені потрібно проконсультуватися зі спеціалістом." } },
    { "id": "v-09-048", "ro": "medicament", "en": "medicine / medication", "uk": "ліки / медикамент", "pronunciation": "meh-dee-kah-MEHNT", "partOfSpeech": "noun", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Acest medicament se ia după masă.", "en": "This medicine is taken after meals.", "uk": "Ці ліки приймають після їжі." } },
    { "id": "v-09-049", "ro": "pastilă", "en": "pill / tablet", "uk": "таблетка", "pronunciation": "pahs-TEE-luh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Luați câte o pastilă de două ori pe zi.", "en": "Take one pill twice a day.", "uk": "Приймайте по одній таблетці двічі на день." } },
    { "id": "v-09-050", "ro": "injecție", "en": "injection / shot", "uk": "ін'єкція / укол", "pronunciation": "een-JEHK-tsee-eh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Am nevoie de o injecție.", "en": "I need an injection.", "uk": "Мені потрібен укол." } },
    { "id": "v-09-051", "ro": "rețetă", "en": "prescription", "uk": "рецепт", "pronunciation": "reh-TSEH-tuh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Aveți rețetă de la doctor?", "en": "Do you have a prescription from the doctor?", "uk": "У вас є рецепт від лікаря?" }, "notes": { "en": "'Rețetă' means both medical prescription and cooking recipe in Romanian.", "uk": "'Rețetă' означає і медичний рецепт, і кулінарний рецепт у румунській мові." } },
    { "id": "v-09-052", "ro": "bandaj", "en": "bandage", "uk": "бинт / пов'язка", "pronunciation": "bahn-DAHZH", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Am nevoie de un bandaj pentru rană.", "en": "I need a bandage for the wound.", "uk": "Мені потрібен бинт для рани." } },
    { "id": "v-09-053", "ro": "termometru", "en": "thermometer", "uk": "термометр", "pronunciation": "tehr-moh-MEH-troo", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Pune termometrul sub limbă.", "en": "Put the thermometer under your tongue.", "uk": "Покладіть термометр під язик." } },
    { "id": "v-09-054", "ro": "sirop", "en": "syrup (medicine)", "uk": "сироп", "pronunciation": "see-ROHP", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Siropul de tuse ajută foarte mult.", "en": "Cough syrup helps a lot.", "uk": "Сироп від кашлю дуже допомагає." } },
    { "id": "v-09-055", "ro": "antibiotic", "en": "antibiotic", "uk": "антибіотик", "pronunciation": "ahn-tee-bee-OH-teek", "partOfSpeech": "noun", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "Nu luați antibiotice fără rețetă.", "en": "Don't take antibiotics without a prescription.", "uk": "Не приймайте антибіотики без рецепта." } },
    { "id": "v-09-056", "ro": "vaccin", "en": "vaccine", "uk": "вакцина", "pronunciation": "vahk-CHEEN", "partOfSpeech": "noun", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "M-am vaccinat împotriva gripei.", "en": "I got vaccinated against the flu.", "uk": "Я вакцинувався від грипу." } },
    { "id": "v-09-057", "ro": "analiză de sânge", "en": "blood test", "uk": "аналіз крові", "pronunciation": "ah-nah-LEE-zuh deh SUHN-jeh", "partOfSpeech": "phrase", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "Trebuie să fac analize de sânge.", "en": "I need to do blood tests.", "uk": "Мені потрібно зробити аналіз крові." } },
    { "id": "v-09-058", "ro": "sănătos", "en": "healthy", "uk": "здоровий", "pronunciation": "suh-nuh-TOHS", "partOfSpeech": "adjective", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Este important să mâncăm sănătos.", "en": "It is important to eat healthy.", "uk": "Важливо харчуватися здорово." } },
