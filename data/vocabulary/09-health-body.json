    { "id": "v-09-034", "ro": "dentist", "en": "dentist", "uk": "стоматолог", "pronunciation": "dehn-TEEST", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Am programare la dentist mâine.", "en": "I have a dentist appointment tomorrow.", "uk": "У мене запис до стоматолога завтра." } },
    { "id": "v-09-035", "ro": "ambulanță", "en": "ambulance", "uk": "швидка допомога", "pronunciation": "ahm-boo-LAHN-tsuh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Chemați ambulanța!", "en": "Call the ambulance!", "uk": "Викликайте швидку допомогу!" } },
    { "id": "v-09-036", "ro": "urgență", "en": "emergency", "uk": "невідкладна допомога", "pronunciation": "oor-ZHEHN-tsuh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Este o urgență medicală.", "en": "It is a medical emergency.", "uk": "Це невідкладна медична допомога." } },
    { "id": "v-09-037", "ro": "programare", "en": "appointment", "uk": "запис / прийом", "pronunciation": "proh-grah-MAH-reh", "partOfSpeech": "noun", "difficulty": 2, "tags": ["daily-life"], "example": { "ro": "Vreau să fac o programare.", "en": "I want to make an appointment.", "uk": "Я хочу записатися на прийом." } },
    { "id": "v-09-038", "ro": "a durea", "en": "to hurt / to ache", "uk": "боліти", "pronunciation": "ah doo-REH-ah", "partOfSpeech": "verb", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Unde vă doare?", "en": "Where does it hurt?", "uk": "Де у вас болить?" } },
