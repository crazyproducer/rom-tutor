    { "id": "v-09-011", "ro": "stomac", "en": "stomach", "uk": "шлунок", "pronunciation": "stoh-MAHK", "partOfSpeech": "noun", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Mă doare stomacul.", "en": "My stomach hurts.", "uk": "У мене болить шлунок." } },
    { "id": "v-09-012", "ro": "spate", "en": "back", "uk": "спина", "pronunciation": "SPAH-teh", "partOfSpeech": "noun", "difficulty": 1, "tags": ["daily-life", "basic"], "example": { "ro": "Am dureri de spate.", "en": "I have back pain.", "uk": "У мене болить спина." } },
    { "id": "v-09-013", "ro": "piept", "en": "chest", "uk": "груди", "pronunciation": "pyehpt", "partOfSpeech": "noun", "difficulty": 3, "tags": ["daily-life"], "example": { "ro": "Simt o presiune în piept.", "en": "I feel pressure in my chest.", "uk": "Я відчуваю тиск у грудях." } },
