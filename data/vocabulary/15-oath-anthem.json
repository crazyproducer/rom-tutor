    { "id": "v-15-001", "ro": "jur", "en": "I swear", "uk": "я присягаю", "pronunciation": "zhoor", "partOfSpeech": "verb", "example": { "ro": "Jur să fiu devotat patriei.", "en": "I swear to be devoted to the homeland.", "uk": "Я присягаю бути відданим батьківщині." }, "tags": ["oath", "ceremony-essential"], "difficulty": 2 },
