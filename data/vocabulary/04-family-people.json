  "words": [
    { "id": "v-04-001", "ro": "familie", "en": "family", "uk": "сім'я / родина", "pronunciation": "fah-MEE-lee-eh", "partOfSpeech": "noun", "example": { "ro": "Familia mea este mare.", "en": "My family is big.", "uk": "Моя сім'я велика." }, "tags": ["family", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-002", "ro": "mamă / mama", "en": "mother / the mother", "uk": "мама / мама (з артиклем)", "pronunciation": "MAH-muh / MAH-mah", "partOfSpeech": "noun", "example": { "ro": "Mama mea locuiește în Ucraina.", "en": "My mother lives in Ukraine.", "uk": "Моя мама живе в Україні." }, "tags": ["family", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-003", "ro": "tată / tatăl", "en": "father / the father", "uk": "тато / тато (з артиклем)", "pronunciation": "TAH-tuh / TAH-tuhl", "partOfSpeech": "noun", "example": { "ro": "Tatăl meu este pensionar.", "en": "My father is retired.", "uk": "Мій тато на пенсії." }, "tags": ["family", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-004", "ro": "fiu / fiul", "en": "son / the son", "uk": "син / син (з артиклем)", "pronunciation": "fee-oo / FEE-ool", "partOfSpeech": "noun", "example": { "ro": "Fiul meu are zece ani.", "en": "My son is ten years old.", "uk": "Моєму сину десять років." }, "tags": ["family", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-005", "ro": "fiică / fiica", "en": "daughter / the daughter", "uk": "дочка / дочка (з артиклем)", "pronunciation": "fee-EE-kuh / fee-EE-kah", "partOfSpeech": "noun", "example": { "ro": "Fiica mea studiază la universitate.", "en": "My daughter studies at the university.", "uk": "Моя дочка навчається в університеті." }, "tags": ["family", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-006", "ro": "frate / fratele", "en": "brother / the brother", "uk": "брат / брат (з артиклем)", "pronunciation": "FRAH-teh / FRAH-teh-leh", "partOfSpeech": "noun", "example": { "ro": "Fratele meu locuiește în România.", "en": "My brother lives in Romania.", "uk": "Мій брат живе в Румунії." }, "tags": ["family", "basic"], "difficulty": 1 },
    { "id": "v-04-007", "ro": "soră / sora", "en": "sister / the sister", "uk": "сестра / сестра (з артиклем)", "pronunciation": "SOH-ruh / SOH-rah", "partOfSpeech": "noun", "example": { "ro": "Sora mea este doctor.", "en": "My sister is a doctor.", "uk": "Моя сестра лікарка." }, "tags": ["family", "basic"], "difficulty": 1 },
    { "id": "v-04-008", "ro": "soț / soțul", "en": "husband / the husband", "uk": "чоловік / чоловік (з артиклем)", "pronunciation": "sots / SOH-tsool", "partOfSpeech": "noun", "example": { "ro": "Soțul meu se numește Andrei.", "en": "My husband is called Andrei.", "uk": "Мого чоловіка звуть Андрій." }, "tags": ["family", "basic", "ceremony-essential", "relationship"], "difficulty": 1 },
    { "id": "v-04-009", "ro": "soție / soția", "en": "wife / the wife", "uk": "дружина / дружина (з артиклем)", "pronunciation": "SOH-tsee-eh / SOH-tsee-ah", "partOfSpeech": "noun", "example": { "ro": "Soția mea este din Ucraina.", "en": "My wife is from Ukraine.", "uk": "Моя дружина з України." }, "tags": ["family", "basic", "ceremony-essential", "relationship"], "difficulty": 1 },
    { "id": "v-04-010", "ro": "copil / copilul", "en": "child / the child", "uk": "дитина / дитина (з артиклем)", "pronunciation": "koh-PEEL / koh-PEE-lool", "partOfSpeech": "noun", "example": { "ro": "Copilul nostru merge la școală.", "en": "Our child goes to school.", "uk": "Наша дитина ходить до школи." }, "tags": ["family", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-011", "ro": "copii / copiii", "en": "children / the children", "uk": "діти / діти (з артиклем)", "pronunciation": "koh-PEE / koh-PEE-ee", "partOfSpeech": "noun", "example": { "ro": "Am doi copii.", "en": "I have two children.", "uk": "У мене двоє дітей." }, "notes": { "en": "Irregular plural of 'copil'. Very common at the ceremony.", "uk": "Нерегулярна множина від 'copil'. Дуже поширене на церемонії." }, "tags": ["family", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-012", "ro": "bunic / bunicul", "en": "grandfather / the grandfather", "uk": "дідусь / дідусь (з артиклем)", "pronunciation": "boo-NEEK / boo-NEE-kool", "partOfSpeech": "noun", "example": { "ro": "Bunicul meu a fost cetățean român.", "en": "My grandfather was a Romanian citizen.", "uk": "Мій дідусь був громадянином Румунії." }, "tags": ["family", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-013", "ro": "bunică / bunica", "en": "grandmother / the grandmother", "uk": "бабуся / бабуся (з артиклем)", "pronunciation": "boo-NEE-kuh / boo-NEE-kah", "partOfSpeech": "noun", "example": { "ro": "Bunica mea vorbea româna.", "en": "My grandmother spoke Romanian.", "uk": "Моя бабуся говорила румунською." }, "tags": ["family", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-014", "ro": "părinți", "en": "parents", "uk": "батьки", "pronunciation": "puh-REENTS", "partOfSpeech": "noun", "example": { "ro": "Părinții mei sunt din Ucraina.", "en": "My parents are from Ukraine.", "uk": "Мої батьки з України." }, "tags": ["family", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-015", "ro": "nepot / nepoată", "en": "nephew or grandson / niece or granddaughter", "uk": "племінник або онук / племінниця або онука", "pronunciation": "neh-POHT / neh-poh-AH-tuh", "partOfSpeech": "noun", "example": { "ro": "Am un nepot și o nepoată.", "en": "I have a nephew/grandson and a niece/granddaughter.", "uk": "У мене є племінник/онук і племінниця/онука." }, "notes": { "en": "Context determines if it means grandchild or nephew/niece.", "uk": "Контекст визначає, чи це онук чи племінник." }, "tags": ["family", "basic"], "difficulty": 2 },
    { "id": "v-04-016", "ro": "unchi / unchiul", "en": "uncle / the uncle", "uk": "дядько / дядько (з артиклем)", "pronunciation": "OONK / OON-kyool", "partOfSpeech": "noun", "example": { "ro": "Unchiul meu locuiește în București.", "en": "My uncle lives in Bucharest.", "uk": "Мій дядько живе в Бухаресті." }, "tags": ["family"], "difficulty": 1 },
    { "id": "v-04-017", "ro": "mătușă / mătușa", "en": "aunt / the aunt", "uk": "тітка / тітка (з артиклем)", "pronunciation": "muh-TOO-shuh / muh-TOO-shah", "partOfSpeech": "noun", "example": { "ro": "Mătușa mea gătește foarte bine.", "en": "My aunt cooks very well.", "uk": "Моя тітка дуже добре готує." }, "tags": ["family"], "difficulty": 1 },
    { "id": "v-04-018", "ro": "văr / verișoară", "en": "cousin (m) / cousin (f)", "uk": "двоюрідний брат / двоюрідна сестра", "pronunciation": "vuhr / veh-ree-SHOAH-ruh", "partOfSpeech": "noun", "example": { "ro": "Am o verișoară în România.", "en": "I have a cousin (f) in Romania.", "uk": "У мене є двоюрідна сестра в Румунії." }, "tags": ["family"], "difficulty": 2 },
    { "id": "v-04-019", "ro": "naș / nașă", "en": "godfather / godmother", "uk": "хрещений батько / хрещена мати", "pronunciation": "nahsh / NAH-shuh", "partOfSpeech": "noun", "example": { "ro": "Nașul nostru este un om foarte bun.", "en": "Our godfather is a very good person.", "uk": "Наш хрещений батько дуже хороша людина." }, "notes": { "en": "In Romanian culture, godparents have an important role at weddings and baptisms.", "uk": "У румунській культурі хрещені відіграють важливу роль на весіллях та хрещеннях." }, "tags": ["family", "relationship"], "difficulty": 2 },
    { "id": "v-04-020", "ro": "socru / soacră", "en": "father-in-law / mother-in-law", "uk": "тесть або свекор / теща або свекруха", "pronunciation": "SOH-kroo / SOAH-kruh", "partOfSpeech": "noun", "example": { "ro": "Soacra mea locuiește cu noi.", "en": "My mother-in-law lives with us.", "uk": "Моя свекруха живе з нами." }, "tags": ["family"], "difficulty": 2 },
    { "id": "v-04-021", "ro": "cumnat / cumnată", "en": "brother-in-law / sister-in-law", "uk": "шурин або зять / зовиця або невістка", "pronunciation": "koom-NAHT / koom-NAH-tuh", "partOfSpeech": "noun", "example": { "ro": "Cumnatul meu este inginer.", "en": "My brother-in-law is an engineer.", "uk": "Мій шурин інженер." }, "tags": ["family"], "difficulty": 2 },
    { "id": "v-04-022", "ro": "ginere", "en": "son-in-law", "uk": "зять", "pronunciation": "DJEE-neh-reh", "partOfSpeech": "noun", "example": { "ro": "Ginerele nostru este din Moldova.", "en": "Our son-in-law is from Moldova.", "uk": "Наш зять з Молдови." }, "tags": ["family"], "difficulty": 2 },
    { "id": "v-04-023", "ro": "noră", "en": "daughter-in-law", "uk": "невістка", "pronunciation": "NOH-ruh", "partOfSpeech": "noun", "example": { "ro": "Nora noastră lucrează la spital.", "en": "Our daughter-in-law works at the hospital.", "uk": "Наша невістка працює в лікарні." }, "tags": ["family"], "difficulty": 2 },
    { "id": "v-04-024", "ro": "străbunic / străbunică", "en": "great-grandfather / great-grandmother", "uk": "прадідусь / прабабуся", "pronunciation": "struh-boo-NEEK / struh-boo-NEE-kuh", "partOfSpeech": "noun", "example": { "ro": "Străbunicul meu s-a născut în România.", "en": "My great-grandfather was born in Romania.", "uk": "Мій прадідусь народився в Румунії." }, "tags": ["family", "ceremony-essential"], "difficulty": 2 },
