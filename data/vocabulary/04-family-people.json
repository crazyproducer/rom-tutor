    { "id": "v-04-046", "ro": "barbă", "en": "beard", "uk": "борода", "pronunciation": "BAHR-buh", "partOfSpeech": "noun", "example": { "ro": "Tatăl meu are barbă.", "en": "My father has a beard.", "uk": "У мого тата борода." }, "tags": ["description", "appearance"], "difficulty": 1 },
