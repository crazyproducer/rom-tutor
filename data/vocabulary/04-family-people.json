    { "id": "v-04-033", "ro": "nuntă", "en": "wedding", "uk": "весілля", "pronunciation": "NOON-tuh", "partOfSpeech": "noun", "example": { "ro": "Nunta a fost foarte frumoasă.", "en": "The wedding was very beautiful.", "uk": "Весілля було дуже красиве." }, "tags": ["relationship", "family"], "difficulty": 2 },
