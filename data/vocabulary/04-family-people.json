    { "id": "v-04-026", "ro": "căsătorit / căsătorită", "en": "married (m/f)", "uk": "одружений / одружена", "pronunciation": "kuh-suh-toh-REET / kuh-suh-toh-REE-tuh", "partOfSpeech": "adjective", "example": { "ro": "Sunt căsătorit de cinci ani.", "en": "I have been married for five years.", "uk": "Я одружений п'ять років." }, "tags": ["relationship", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-04-027", "ro": "necăsătorit / necăsătorită", "en": "unmarried (m/f)", "uk": "неодружений / неодружена", "pronunciation": "neh-kuh-suh-toh-REET / neh-kuh-suh-toh-REE-tuh", "partOfSpeech": "adjective", "example": { "ro": "Sunt necăsătorit.", "en": "I am unmarried.", "uk": "Я неодружений." }, "tags": ["relationship", "ceremony-essential"], "difficulty": 2 },
