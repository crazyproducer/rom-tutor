    { "id": "v-04-048", "ro": "tânăr / tânără", "en": "young (m/f)", "uk": "молодий / молода", "pronunciation": "tuh-NUHR / tuh-NUH-ruh", "partOfSpeech": "adjective", "example": { "ro": "Suntem o familie tânără.", "en": "We are a young family.", "uk": "Ми молода сім'я." }, "tags": ["description", "age"], "difficulty": 1 },
    { "id": "v-04-049", "ro": "frumos / frumoasă", "en": "handsome / beautiful (m/f)", "uk": "гарний / гарна", "pronunciation": "froo-MOHS / froo-MOAH-suh", "partOfSpeech": "adjective", "example": { "ro": "Soția mea este foarte frumoasă.", "en": "My wife is very beautiful.", "uk": "Моя дружина дуже гарна." }, "tags": ["description", "appearance"], "difficulty": 1 },
