    { "id": "v-04-044", "ro": "față", "en": "face", "uk": "обличчя", "pronunciation": "FAH-tsuh", "partOfSpeech": "noun", "example": { "ro": "Are o față rotundă.", "en": "He/She has a round face.", "uk": "У нього/неї кругле обличчя." }, "tags": ["description", "appearance"], "difficulty": 1 },
