{
  "moduleId": "mod-04",
  "words": [
    { "id": "v-03-001", "ro": "zero", "en": "zero", "uk": "нуль", "pronunciation": "ZEH-roh", "partOfSpeech": "numeral", "example": { "ro": "Temperatura este zero grade.", "en": "The temperature is zero degrees.", "uk": "Температура нуль градусів." }, "tags": ["numeral", "basic"], "difficulty": 1 },
    { "id": "v-03-002", "ro": "unu / una", "en": "one (m/f)", "uk": "один / одна", "pronunciation": "OO-noo / OO-nah", "partOfSpeech": "numeral", "example": { "ro": "Am un copil.", "en": "I have one child.", "uk": "У мене одна дитина." }, "tags": ["numeral", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-03-003", "ro": "doi / două", "en": "two (m/f)", "uk": "два / дві", "pronunciation": "doy / DOH-uh", "partOfSpeech": "numeral", "example": { "ro": "Am doi copii.", "en": "I have two children.", "uk": "У мене двоє дітей." }, "tags": ["numeral", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-03-004", "ro": "trei", "en": "three", "uk": "три", "pronunciation": "trey", "partOfSpeech": "numeral", "example": { "ro": "Sunt trei persoane aici.", "en": "There are three people here.", "uk": "Тут три людини." }, "tags": ["numeral", "basic"], "difficulty": 1 },
    { "id": "v-03-005", "ro": "patru", "en": "four", "uk": "чотири", "pronunciation": "PAH-troo", "partOfSpeech": "numeral", "example": { "ro": "Am patru frați.", "en": "I have four brothers.", "uk": "У мене чотири брати." }, "tags": ["numeral", "basic"], "difficulty": 1 },
    { "id": "v-03-006", "ro": "cinci", "en": "five", "uk": "п'ять", "pronunciation": "cheench", "partOfSpeech": "numeral", "example": { "ro": "Locuiesc aici de cinci ani.", "en": "I have lived here for five years.", "uk": "Я живу тут п'ять років." }, "tags": ["numeral", "basic", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-03-007", "ro": "șase", "en": "six", "uk": "шість", "pronunciation": "SHAH-seh", "partOfSpeech": "numeral", "example": { "ro": "Sunt șase luni de când am aplicat.", "en": "It has been six months since I applied.", "uk": "Минуло шість місяців відколи я подав заявку." }, "tags": ["numeral", "basic"], "difficulty": 1 },
    { "id": "v-03-008", "ro": "șapte", "en": "seven", "uk": "сім", "pronunciation": "SHAHP-teh", "partOfSpeech": "numeral", "example": { "ro": "Săptămâna are șapte zile.", "en": "The week has seven days.", "uk": "У тижні сім днів." }, "tags": ["numeral", "basic"], "difficulty": 1 },
    { "id": "v-03-009", "ro": "opt", "en": "eight", "uk": "вісім", "pronunciation": "ohpt", "partOfSpeech": "numeral", "example": { "ro": "Ne vedem la ora opt.", "en": "We meet at eight o'clock.", "uk": "Зустрінемось о восьмій." }, "tags": ["numeral", "basic"], "difficulty": 1 },
    { "id": "v-03-010", "ro": "nouă", "en": "nine", "uk": "дев'ять", "pronunciation": "NOH-uh", "partOfSpeech": "numeral", "example": { "ro": "Ceremonia începe la nouă.", "en": "The ceremony starts at nine.", "uk": "Церемонія починається о дев'ятій." }, "notes": { "en": "Same spelling as 'nouă' (new, feminine) and 'nouă' (to us). Context makes the meaning clear.", "uk": "Те саме написання що й 'nouă' (нова) та 'nouă' (нам). Контекст вказує на значення." }, "tags": ["numeral", "basic"], "difficulty": 1 },
    { "id": "v-03-011", "ro": "zece", "en": "ten", "uk": "десять", "pronunciation": "ZEH-cheh", "partOfSpeech": "numeral", "example": { "ro": "Am zece documente.", "en": "I have ten documents.", "uk": "У мене десять документів." }, "tags": ["numeral", "basic"], "difficulty": 1 },
    { "id": "v-03-012", "ro": "unsprezece", "en": "eleven", "uk": "одинадцять", "pronunciation": "oon-SPREH-zeh-cheh", "partOfSpeech": "numeral", "example": { "ro": "Sunt unsprezece persoane în sală.", "en": "There are eleven people in the room.", "uk": "В залі одинадцять людей." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-013", "ro": "doisprezece", "en": "twelve", "uk": "дванадцять", "pronunciation": "doy-SPREH-zeh-cheh", "partOfSpeech": "numeral", "example": { "ro": "Anul are doisprezece luni.", "en": "The year has twelve months.", "uk": "У році дванадцять місяців." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-014", "ro": "treisprezece", "en": "thirteen", "uk": "тринадцять", "pronunciation": "trey-SPREH-zeh-cheh", "partOfSpeech": "numeral", "example": { "ro": "Avem treisprezece candidați.", "en": "We have thirteen candidates.", "uk": "У нас тринадцять кандидатів." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-015", "ro": "paisprezece", "en": "fourteen", "uk": "чотирнадцять", "pronunciation": "pie-SPREH-zeh-cheh", "partOfSpeech": "numeral", "example": { "ro": "Copilul are paisprezece ani.", "en": "The child is fourteen years old.", "uk": "Дитині чотирнадцять років." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-016", "ro": "cincisprezece", "en": "fifteen", "uk": "п'ятнадцять", "pronunciation": "cheench-SPREH-zeh-cheh", "partOfSpeech": "numeral", "example": { "ro": "Așteptăm cincisprezece minute.", "en": "We wait fifteen minutes.", "uk": "Ми чекаємо п'ятнадцять хвилин." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-017", "ro": "șaisprezece", "en": "sixteen", "uk": "шістнадцять", "pronunciation": "shie-SPREH-zeh-cheh", "partOfSpeech": "numeral", "example": { "ro": "Are șaisprezece ani.", "en": "He/she is sixteen years old.", "uk": "Йому/їй шістнадцять років." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-018", "ro": "șaptesprezece", "en": "seventeen", "uk": "сімнадцять", "pronunciation": "SHAHP-teh-SPREH-zeh-cheh", "partOfSpeech": "numeral", "example": { "ro": "Locuiesc la etajul șaptesprezece.", "en": "I live on the seventeenth floor.", "uk": "Я живу на сімнадцятому поверсі." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-019", "ro": "optsprezece", "en": "eighteen", "uk": "вісімнадцять", "pronunciation": "ohpt-SPREH-zeh-cheh", "partOfSpeech": "numeral", "example": { "ro": "La optsprezece ani poți vota.", "en": "At eighteen you can vote.", "uk": "У вісімнадцять років можна голосувати." }, "tags": ["numeral", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-03-020", "ro": "nouăsprezece", "en": "nineteen", "uk": "дев'ятнадцять", "pronunciation": "NOH-uh-SPREH-zeh-cheh", "partOfSpeech": "numeral", "example": { "ro": "Am plecat din Ucraina la nouăsprezece ani.", "en": "I left Ukraine at nineteen years old.", "uk": "Я виїхав з України у дев'ятнадцять років." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-021", "ro": "douăzeci", "en": "twenty", "uk": "двадцять", "pronunciation": "DOH-uh-zech", "partOfSpeech": "numeral", "example": { "ro": "Ceremonia durează douăzeci de minute.", "en": "The ceremony lasts twenty minutes.", "uk": "Церемонія триває двадцять хвилин." }, "tags": ["numeral", "ceremony-essential"], "difficulty": 1 },
    { "id": "v-03-022", "ro": "treizeci", "en": "thirty", "uk": "тридцять", "pronunciation": "TREY-zech", "partOfSpeech": "numeral", "example": { "ro": "Am treizeci de ani.", "en": "I am thirty years old.", "uk": "Мені тридцять років." }, "tags": ["numeral", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-03-023", "ro": "patruzeci", "en": "forty", "uk": "сорок", "pronunciation": "PAH-troo-zech", "partOfSpeech": "numeral", "example": { "ro": "Tatăl meu are patruzeci de ani.", "en": "My father is forty years old.", "uk": "Моєму батькові сорок років." }, "tags": ["numeral", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-03-024", "ro": "cincizeci", "en": "fifty", "uk": "п'ятдесят", "pronunciation": "CHEENCH-zech", "partOfSpeech": "numeral", "example": { "ro": "Există cincizeci de candidați.", "en": "There are fifty candidates.", "uk": "Є п'ятдесят кандидатів." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-025", "ro": "șaizeci", "en": "sixty", "uk": "шістдесят", "pronunciation": "SHIE-zech", "partOfSpeech": "numeral", "example": { "ro": "O oră are șaizeci de minute.", "en": "An hour has sixty minutes.", "uk": "У годині шістдесят хвилин." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-026", "ro": "șaptezeci", "en": "seventy", "uk": "сімдесят", "pronunciation": "SHAHP-teh-zech", "partOfSpeech": "numeral", "example": { "ro": "Bunicul are șaptezeci de ani.", "en": "Grandfather is seventy years old.", "uk": "Дідусеві сімдесят років." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-027", "ro": "optzeci", "en": "eighty", "uk": "вісімдесят", "pronunciation": "OHPT-zech", "partOfSpeech": "numeral", "example": { "ro": "Au venit optzeci de persoane.", "en": "Eighty people came.", "uk": "Прийшло вісімдесят людей." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-028", "ro": "nouăzeci", "en": "ninety", "uk": "дев'яносто", "pronunciation": "NOH-uh-zech", "partOfSpeech": "numeral", "example": { "ro": "Examenul durează nouăzeci de minute.", "en": "The exam lasts ninety minutes.", "uk": "Іспит триває дев'яносто хвилин." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-029", "ro": "o sută", "en": "one hundred", "uk": "сто", "pronunciation": "oh SOO-tuh", "partOfSpeech": "numeral", "example": { "ro": "Am învățat o sută de cuvinte.", "en": "I learned one hundred words.", "uk": "Я вивчив сто слів." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-030", "ro": "o mie", "en": "one thousand", "uk": "тисяча", "pronunciation": "oh MEE-eh", "partOfSpeech": "numeral", "example": { "ro": "Orașul are o mie de locuitori.", "en": "The town has one thousand inhabitants.", "uk": "У місті тисяча жителів." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-031", "ro": "un milion", "en": "one million", "uk": "мільйон", "pronunciation": "oon mee-lee-OHN", "partOfSpeech": "numeral", "example": { "ro": "București are peste un milion de locuitori.", "en": "Bucharest has over one million inhabitants.", "uk": "У Бухаресті понад мільйон жителів." }, "tags": ["numeral"], "difficulty": 2 },
    { "id": "v-03-032", "ro": "primul / prima", "en": "first (m/f)", "uk": "перший / перша", "pronunciation": "PREEM-ool / PREE-mah", "partOfSpeech": "numeral", "example": { "ro": "Este prima mea vizită în România.", "en": "It is my first visit to Romania.", "uk": "Це мій перший візит до Румунії." }, "notes": { "en": "Ordinal numbers in Romanian agree in gender with the noun they describe.", "uk": "Порядкові числівники в румунській узгоджуються в роді з іменником." }, "tags": ["numeral", "basic", "ceremony-essential"], "difficulty": 3 },
    { "id": "v-03-033", "ro": "al doilea / a doua", "en": "second (m/f)", "uk": "другий / друга", "pronunciation": "ahl DOY-leh-ah / ah DOH-ah", "partOfSpeech": "numeral", "example": { "ro": "Este a doua oară când vin aici.", "en": "It is the second time I come here.", "uk": "Це другий раз, коли я приходжу сюди." }, "tags": ["numeral"], "difficulty": 3 },
    { "id": "v-03-034", "ro": "al treilea / a treia", "en": "third (m/f)", "uk": "третій / третя", "pronunciation": "ahl TREY-leh-ah / ah TREY-ah", "partOfSpeech": "numeral", "example": { "ro": "Locuiesc la al treilea etaj.", "en": "I live on the third floor.", "uk": "Я живу на третьому поверсі." }, "tags": ["numeral"], "difficulty": 3 },
    { "id": "v-03-035", "ro": "al patrulea / a patra", "en": "fourth (m/f)", "uk": "четвертий / четверта", "pronunciation": "ahl PAH-troo-leh-ah / ah PAH-trah", "partOfSpeech": "numeral", "example": { "ro": "Suntem în al patrulea an de ședere.", "en": "We are in the fourth year of residence.", "uk": "Ми на четвертому році перебування." }, "tags": ["numeral"], "difficulty": 3 },
    { "id": "v-03-036", "ro": "ultimul / ultima", "en": "last (m/f)", "uk": "останній / остання", "pronunciation": "OOL-tee-mool / OOL-tee-mah", "partOfSpeech": "adjective", "example": { "ro": "Aceasta este ultima etapă pentru cetățenie.", "en": "This is the last step for citizenship.", "uk": "Це останній етап для отримання громадянства." }, "tags": ["numeral", "ceremony-essential"], "difficulty": 3 },
    { "id": "v-03-037", "ro": "luni", "en": "Monday", "uk": "понеділок", "pronunciation": "loon", "partOfSpeech": "noun", "example": { "ro": "Luni merg la birou.", "en": "On Monday I go to the office.", "uk": "У понеділок я йду в офіс." }, "notes": { "en": "Days of the week in Romanian are not capitalized unless at the start of a sentence.", "uk": "Дні тижня в румунській не пишуться з великої літери, якщо не на початку речення." }, "tags": ["calendar", "daily-life", "basic"], "difficulty": 1 },
    { "id": "v-03-038", "ro": "marți", "en": "Tuesday", "uk": "вівторок", "pronunciation": "marts", "partOfSpeech": "noun", "example": { "ro": "Marți am programare la ambasadă.", "en": "On Tuesday I have an appointment at the embassy.", "uk": "У вівторок у мене запис до посольства." }, "tags": ["calendar", "daily-life", "basic"], "difficulty": 1 },
    { "id": "v-03-039", "ro": "miercuri", "en": "Wednesday", "uk": "середа", "pronunciation": "mee-EHR-koor", "partOfSpeech": "noun", "example": { "ro": "Miercuri avem ceremonia.", "en": "On Wednesday we have the ceremony.", "uk": "У середу в нас церемонія." }, "tags": ["calendar", "daily-life", "basic"], "difficulty": 1 },
    { "id": "v-03-040", "ro": "joi", "en": "Thursday", "uk": "четвер", "pronunciation": "zhoy", "partOfSpeech": "noun", "example": { "ro": "Joi primim documentele.", "en": "On Thursday we receive the documents.", "uk": "У четвер ми отримуємо документи." }, "tags": ["calendar", "daily-life", "basic"], "difficulty": 1 },
    { "id": "v-03-041", "ro": "vineri", "en": "Friday", "uk": "п'ятниця", "pronunciation": "VEE-nehr", "partOfSpeech": "noun", "example": { "ro": "Vineri nu lucrăm.", "en": "On Friday we don't work.", "uk": "У п'ятницю ми не працюємо." }, "tags": ["calendar", "daily-life", "basic"], "difficulty": 1 },
    { "id": "v-03-042", "ro": "sâmbătă", "en": "Saturday", "uk": "субота", "pronunciation": "suhm-BUH-tuh", "partOfSpeech": "noun", "example": { "ro": "Sâmbătă merg la piață.", "en": "On Saturday I go to the market.", "uk": "У суботу я йду на ринок." }, "tags": ["calendar", "daily-life", "basic"], "difficulty": 1 },
    { "id": "v-03-043", "ro": "duminică", "en": "Sunday", "uk": "неділя", "pronunciation": "doo-MEE-nee-kuh", "partOfSpeech": "noun", "example": { "ro": "Duminică ne odihnim.", "en": "On Sunday we rest.", "uk": "У неділю ми відпочиваємо." }, "tags": ["calendar", "daily-life", "basic"], "difficulty": 1 },
    { "id": "v-03-044", "ro": "ianuarie", "en": "January", "uk": "січень", "pronunciation": "yah-noo-AH-ree-eh", "partOfSpeech": "noun", "example": { "ro": "M-am născut în ianuarie.", "en": "I was born in January.", "uk": "Я народився в січні." }, "tags": ["calendar", "date", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-03-045", "ro": "februarie", "en": "February", "uk": "лютий", "pronunciation": "feb-roo-AH-ree-eh", "partOfSpeech": "noun", "example": { "ro": "Februarie este o lună scurtă.", "en": "February is a short month.", "uk": "Лютий — короткий місяць." }, "tags": ["calendar", "date"], "difficulty": 2 },
    { "id": "v-03-046", "ro": "martie", "en": "March", "uk": "березень", "pronunciation": "MAHR-tee-eh", "partOfSpeech": "noun", "example": { "ro": "În martie vine primăvara.", "en": "In March spring comes.", "uk": "У березні приходить весна." }, "tags": ["calendar", "date"], "difficulty": 2 },
    { "id": "v-03-047", "ro": "aprilie", "en": "April", "uk": "квітень", "pronunciation": "ah-PREE-lee-eh", "partOfSpeech": "noun", "example": { "ro": "Paștele este în aprilie.", "en": "Easter is in April.", "uk": "Великдень у квітні." }, "tags": ["calendar", "date"], "difficulty": 2 },
    { "id": "v-03-048", "ro": "mai", "en": "May", "uk": "травень", "pronunciation": "my", "partOfSpeech": "noun", "example": { "ro": "În mai avem multe sărbători.", "en": "In May we have many holidays.", "uk": "У травні ми маємо багато свят." }, "notes": { "en": "Also means 'more' or 'still' as an adverb. Context makes the meaning clear.", "uk": "Також означає 'більше' або 'ще' як прислівник. Контекст вказує на значення." }, "tags": ["calendar", "date"], "difficulty": 2 },
    { "id": "v-03-049", "ro": "iunie", "en": "June", "uk": "червень", "pronunciation": "YOO-nee-eh", "partOfSpeech": "noun", "example": { "ro": "Ceremonia este în iunie.", "en": "The ceremony is in June.", "uk": "Церемонія в червні." }, "tags": ["calendar", "date"], "difficulty": 2 },
    { "id": "v-03-050", "ro": "iulie", "en": "July", "uk": "липень", "pronunciation": "YOO-lee-eh", "partOfSpeech": "noun", "example": { "ro": "În iulie este foarte cald.", "en": "In July it is very hot.", "uk": "У липні дуже спекотно." }, "tags": ["calendar", "date"], "difficulty": 2 },
    { "id": "v-03-051", "ro": "august", "en": "August", "uk": "серпень", "pronunciation": "ah-OOST", "partOfSpeech": "noun", "example": { "ro": "Ne mutăm în august.", "en": "We move in August.", "uk": "Ми переїжджаємо в серпні." }, "tags": ["calendar", "date"], "difficulty": 2 },
    { "id": "v-03-052", "ro": "septembrie", "en": "September", "uk": "вересень", "pronunciation": "sep-TEM-bree-eh", "partOfSpeech": "noun", "example": { "ro": "Școala începe în septembrie.", "en": "School starts in September.", "uk": "Школа починається у вересні." }, "tags": ["calendar", "date"], "difficulty": 2 },
    { "id": "v-03-053", "ro": "octombrie", "en": "October", "uk": "жовтень", "pronunciation": "ohk-TOHM-bree-eh", "partOfSpeech": "noun", "example": { "ro": "În octombrie se schimbă ora.", "en": "In October the clocks change.", "uk": "У жовтні переводять годинники." }, "tags": ["calendar", "date"], "difficulty": 2 },
    { "id": "v-03-054", "ro": "noiembrie", "en": "November", "uk": "листопад", "pronunciation": "noh-YEM-bree-eh", "partOfSpeech": "noun", "example": { "ro": "Am depus cererea în noiembrie.", "en": "I submitted the application in November.", "uk": "Я подав заяву в листопаді." }, "tags": ["calendar", "date"], "difficulty": 2 },
    { "id": "v-03-055", "ro": "decembrie", "en": "December", "uk": "грудень", "pronunciation": "deh-CHEM-bree-eh", "partOfSpeech": "noun", "example": { "ro": "Ziua Națională este pe 1 decembrie.", "en": "The National Day is on December 1st.", "uk": "Національний день — 1 грудня." }, "tags": ["calendar", "date", "ceremony-essential"], "difficulty": 2 },
    { "id": "v-03-056", "ro": "oră", "en": "hour / o'clock", "uk": "година", "pronunciation": "OH-ruh", "partOfSpeech": "noun", "example": { "ro": "Este ora zece.", "en": "It is ten o'clock.", "uk": "Десята година." }, "tags": ["time", "basic"], "difficulty": 1 },
    { "id": "v-03-057", "ro": "minut", "en": "minute", "uk": "хвилина", "pronunciation": "mee-NOOT", "partOfSpeech": "noun", "example": { "ro": "Așteptați cinci minute, vă rog.", "en": "Please wait five minutes.", "uk": "Зачекайте п'ять хвилин, будь ласка." }, "tags": ["time", "basic"], "difficulty": 1 },
